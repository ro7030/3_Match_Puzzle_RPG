  m_Script: {fileID: 11500000, guid: d5ebec344a07c0b4fac788942570856a, type: 3}
  m_Name: After_Chapter2_Stage2
  m_EditorClassIdentifier: Assembly-CSharp::Story.CutsceneData
  cutsceneId: 
  nextSceneName: MapScene
  isPrologueMode: 1
  clearSaveOnComplete: 0
  dialogueLines:
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uBBF8\uBBF9\uC774 \uC5F0\uAE30\uAC00 \uB418\uC5B4 \uC0AC\uB77C\uC9C0\uACE0,
      \uBC14\uB2E5\uC5D0\uB294 \uB0A1\uC740 \uC7A1\uB3D9\uC0AC\uB2C8 \uBA87 \uAC1C\uB9CC
      \uB0A8\uB294\uB2E4."
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 2
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uB2E4\uC774\uB098"
    text: "\"\uC544... \uB0B4 \uD669\uAE08 \uBCF4\uBB3C... \uB0B4 \uC77C\uD655\uCC9C\uAE08\uC758
      \uAFC8\uC774... \uACE0\uC791 \uD613\uBC14\uB2E5\uC774 \uC2DC\uD37C\uB7F0 \uAD34\uBB3C\uC774\uC5C8\uB2E4\uB2C8!\""
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC18C\uD53C\uC544\uB294 \uC815\uB9D0 \uD55C\uC2EC\uD558\uB2E4\uB294 \uD45C\uC815\uC73C\uB85C
      \uD600\uB97C \uCC28\uB354\uB2C8, \uB4E4\uACE0 \uC788\uB358 \uC9C0\uD321\uC774
      \uB05D\uC73C\uB85C \uB2E4\uC774\uB098\uC758 \uB4F1\uC744 \uCF55\uCF55 \uCC0C\uB974\uBA70
      \uAC00\uCC28 \uC5C6\uB294 \uB3C5\uC124\uC744 \uB0B4\uBC49\uC5C8\uB2E4."
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC18C\uD53C\uC544"
    text: "\"\uB2F9\uC5F0\uD558\uC8E0. \uC720\uC801 \uCD5C\uC2EC\uCE35\uC5D0 \uC800\uB807\uAC8C
      \uB300\uB193\uACE0 '\uB098 \uBCF4\uBB3C\uC774\uC5D0\uC694' \uD558\uACE0 \uB193\uC778
      \uC0C1\uC790\uAC00 \uC815\uC0C1\uC77C \uB9AC \uC5C6\uC796\uC544\uC694. 300\uB144\uC774\uB098
      \uC0AC\uC168\uB2E4\uBA74\uC11C \uC9C0\uB2A5\uC740 \uC2AC\uB77C\uC784 \uC218\uC900\uC778\uAC00\uC694?\""
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 2
    characterSpriteOverride: {fileID: 8208410677223932748, guid: 1f7a98451c62a8a4b81e98e577e5b8c2, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uB2E4\uC774\uB098"
    text: "\"\uBB34, \uBB34\uC2A8 \uB9D0\uC774 \uADF8\uB798! \uC6D0\uB798 \uC704\uAE30\uB294
      \uAE30\uD68C\uB77C\uACE0, \uC800\uB7F0 \uACF3\uC5D0 \uC9C4\uC9DC '\uB4DD\uD15C'\uC774
      \uC228\uACA8\uC838 \uC788\uB294 \uAC8C \uBAA8\uD5D8\uC758 \uC815\uC11D\uC774\uB780
      \uB9D0\uC774\uC57C!\""
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC5D8\uB9AC\uC57C\uB294 \uC5B4\uC774\uAC00 \uC5C6\uB2E4\uB294 \uB4EF
      \uD5C8\uD0C8\uD55C \uC6C3\uC74C\uC744 \uC9C0\uC73C\uBA70, \uBF51\uC544 \uB4E4\uC5C8\uB358
      \uAC80\uC744 \uC870\uC6A9\uD788 \uCE7C\uC9D1\uC5D0 \uBC00\uC5B4 \uB123\uC5C8\uB2E4.
      \uAE34\uBC15\uD588\uB358 \uC804\uD22C\uC758 \uC5F4\uAE30\uAC00 \uC2DD\uC790
      \uADF8\uB294 \uBE44\uB85C\uC18C \uC548\uB3C4\uC758 \uD55C\uC228\uC744 \uB0B4\uC26C\uC5C8\uB2E4."
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: " \"\uD558\uD558, \uADF8\uB798\uB3C4 \uB2E4\uC774\uB098 \uC528 \uB355\uBD84\uC5D0
      \uAE34\uC7A5\uC774 \uC880 \uD480\uB838\uB124\uC694. \uC138\uC2E4\uB9AC\uC544
      \uB2D8\uC774 \uACBD\uACE0\uD558\uC9C0 \uC54A\uC558\uB2E4\uBA74 \uC815\uB9D0
      \uD070\uC77C \uB0A0 \uBED4\uD588\uC2B5\uB2C8\uB2E4.\""
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC138\uC2E4\uB9AC\uC544\uAC00 \uC0DD\uAE0B \uBBF8\uC18C \uC9C0\uC73C\uBA70
      \uB2E4\uC774\uB098\uC5D0\uAC8C \uB2E4\uAC00\uC640 \uADF8\uB140\uC758 \uC637\uC5D0
      \uBB3B\uC740 \uBA3C\uC9C0\uB97C \uC815\uC131\uC2A4\uB7FD\uAC8C \uD138\uC5B4\uC8FC\uC5C8\uB2E4.
      \uD558\uC9C0\uB9CC \uADF8 \uBD80\uB4DC\uB7EC\uC6B4 \uC190\uAE38\uACFC\uB294
      \uB300\uC870\uC801\uC73C\uB85C, \uB2E4\uC774\uB098\uC758 \uC5B4\uAE68\uC5D0\uB294
      \uB9C8\uCE58 \uAC70\uB300\uD55C \uBC14\uC704\uAC00 \uC5B9\uC5B4\uC9C4 \uB4EF\uD55C
      \uC544\uC8FC \uBB34\uAC70\uC6B4 \uC911\uC555\uAC10\uC774 \uC2E4\uB824 \uC788\uC5C8\uB2E4.
      \uC138\uC2E4\uB9AC\uC544\uC758 \uC190\uB4F1 \uC704\uB85C \uD478\uB978 \uD798\uC904\uC774
      \uB3CB\uC544\uB0A0 \uB9CC\uD07C \uAC15\uD55C \uC555\uBC15\uC774\uC5C8\uB2E4."
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 3
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC138\uC2E4\uB9AC\uC544"
    text: "\"\uB2E4\uC774\uB098 \uB2D8? \uC9C0\uAE08\uC740 \uD3C9\uBC94\uD55C \uC0C1\uC2DD\uC774
      \uD1B5\uD558\uC9C0 \uC54A\uB294 \uACF3\uC774\uB2C8, \uC870\uAE08 \uB354 '\uACBD\uAC01\uC2EC'\uC744
      \uAC00\uC838\uC8FC\uC2DC\uBA74 \uC88B\uC744 \uAC83 \uAC19\uC544\uC694. \uC54C\uACA0\uC8E0?\""
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 2
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uB2E4\uC774\uB098"
    text: "\"\uD788, \uD788\uC775...! \uC5B4, \uC5B4\uC5B4... \uC54C\uC558\uC5B4!
      \uC54C\uC558\uC73C\uB2C8\uAE4C \uADF8 \uC6C3\uB294 \uC5BC\uAD74\uB85C \uC5B4\uAE68
      \uC880 \uAF49 \uB204\uB974\uC9C0 \uB9C8! \uBF08 \uBD80\uB7EC\uC9C0\uACA0\uC5B4...!\""
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uC138\uC2E4\uB9AC\uC544 \uB2D8... \uC6C3\uACE0 \uACC4\uC2DC\uC9C0\uB9CC
      \uBFDC\uC5B4\uB0B4\uB294 \uAE30\uC138\uAC00 \uC7A5\uB09C\uC774 \uC544\uB2C8\uAD70.
      \uC5ED\uC2DC \uC131\uB140\uC758 \uC790\uB9AC\uC5D0 \uC624\uB978 \uBD84\uC740
      \uBB54\uAC00 \uB2EC\uB77C\uB3C4 \uB2E4\uB974\uB2E4.'"
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC18C\uD53C\uC544\uB294 \uC774 \uAD11\uACBD\uC774 \uC9C8\uB9B0\uB2E4\uB294
      \uB4EF \uACE0\uAC1C\uB97C \uB3CC\uB824 \uC5B4\uB450\uC6B4 \uC720\uC801 \uC548\uCABD\uC744
      \uC751\uC2DC\uD588\uB2E4. \uADF8\uB140\uC758 \uB208\uB3D9\uC790\uAC00 \uB2E4\uC2DC\uAE08
      \uCC28\uAC11\uAC8C \uAC00\uB77C\uC549\uC558\uB2E4.\r\n"
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC18C\uD53C\uC544"
    text: "\"\uBC14\uBCF4 \uAC19\uC740 \uC18C\uB9AC \uADF8\uB9CC\uD558\uACE0 \uC5B4\uC11C
      \uC6C0\uC9C1\uC5EC\uC694. \uC800 \uC55E\uC758 \uACF5\uAE30\uAC00 \uC2EC\uC0C1\uCE58
      \uC54A\uC73C\uB2C8\uAE4C.\""
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
