  m_Script: {fileID: 11500000, guid: d5ebec344a07c0b4fac788942570856a, type: 3}
  m_Name: Before_Chapter1_Stage3
  m_EditorClassIdentifier: Assembly-CSharp::Story.CutsceneData
  cutsceneId: 
  nextSceneName: BattleScene
  isPrologueMode: 1
  clearSaveOnComplete: 0
  dialogueLines:
  - characterId: -1
    characterSpriteOverride: {fileID: 127687315839032673, guid: 791b44c63291f7849b8e0ee0ebad34c4, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uACE0\uB9C9\uC744 \uCC22\uC744 \uB4EF\uD55C \uC721\uC911\uD55C \uBC1C\uC18C\uB9AC\uAC00
      \uC232\uC758 \uC815\uC801\uC744 \uBB34\uCC38\uD788 \uAE68\uBD80\uC218\uBA70
      \uB2E4\uAC00\uC654\uB2E4. \uC774\uC73D\uACE0 \uC9D9\uC740 \uC218\uD480\uC744
      \uD5E4\uCE58\uACE0 \uB098\uD0C0\uB09C \uAC83\uC740 \uC77C\uBC18\uC801\uC778
      \uC624\uD06C\uBCF4\uB2E4 \uB450 \uBC30\uB294 \uAC70\uB300\uD55C, \uAD34\uBB3C
      \uAC19\uC740 \uCCB4\uAD6C\uC758 '\uC624\uD06C \uC655'\uC774\uC5C8\uB2E4. \uB188\uC774
      \uD53C\uB85C \uCC0C\uB4E0 \uAC70\uB300\uD55C \uAC00\uC2DC \uBABD\uB465\uC774\uB97C
      \uBC14\uB2E5\uC5D0 \uC4F8\uBA70 \uB4F1\uC7A5\uD558\uC790, \uC232\uC758 \uACF5\uAE30\uB294
      \uB2E8\uC228\uC5D0 \uD53C\uBE44\uB9B0\uB0B4\uB85C \uBB3C\uB4E4\uC5C8\uB2E4."
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 127687315839032673, guid: 791b44c63291f7849b8e0ee0ebad34c4, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC624\uD06C \uC655"
    text: "\"\uCE68\uC785\uC790... \uC778\uAC04... \uCC22\uC5B4... \uC8FD\uC778\uB2E4...!\"\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 127687315839032673, guid: 791b44c63291f7849b8e0ee0ebad34c4, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uB188\uC758 \uB208\uB3D9\uC790\uB294 \uC774\uC131\uC744 \uC783\uC740
      \uCC44 \uD54F\uBE5B\uC73C\uB85C \uBC88\uB729\uC600\uACE0, \uC785\uAC00\uC5D0\uC11C\uB294
      \uD5C8\uC5F0 \uAE40\uACFC \uD568\uAED8 \uC9C0\uB3C5\uD55C \uC545\uCDE8\uAC00
      \uBFDC\uC5B4\uC838 \uB098\uC654\uB2E4. \uC5EC\uD0DC\uAECF \uC0C1\uB300\uD574
      \uC628 \uC232\uC758 \uB9C8\uBB3C\uB4E4\uACFC\uB294 \uCC28\uC6D0\uC774 \uB2E4\uB978
      \uC0AC\uB098\uC6B4 \uC704\uC555\uAC10\uC774 \uC77C\uD589\uC758 \uC804\uC2E0\uC744
      \uC9D3\uB20C\uB800\uB2E4."
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uC11C \uC788\uB294 \uAC83\uB9CC\uC73C\uB85C\uB3C4 \uB300\uAE30\uAC00
      \uB5A8\uB9AC\uACE0 \uC788\uB2E4. \uC774\uAC74 \uB2E8\uC21C\uD55C \uC9D0\uC2B9\uC758
      \uC644\uB825\uC774 \uC544\uB2C8\uC57C. \uBCFC\uCF00\uC778\uC758 \uB4A4\uD2C0\uB9B0
      \uB9C8\uB825\uC774 \uB188\uC758 \uADFC\uC721\uC744 \uAC15\uC81C\uB85C \uBD80\uD480\uB9AC\uACE0
      \uD33D\uCC3D\uC2DC\uD0A8 \uAC70\uB2E4. \uC800 \uAC00\uC2DC \uBABD\uB465\uC774\uC5D0
      \uD55C \uBC29\uC774\uB77C\uB3C4 \uC81C\uB300\uB85C \uC2A4\uCE5C\uB2E4\uBA74,
      \uBC29\uD328\uC9F8\uB85C \uBF08\uB3C4 \uBABB \uCD94\uB9AC\uACE0 \uAC00\uB8E8\uAC00
      \uB418\uACA0\uAD70.'"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uB2E4\uC774\uB098\uB294 \uAE34\uC7A5\uD55C \uAE30\uC0C9\uC744 \uC228\uAE30\uB824\uB294
      \uB4EF, \uC624\uD788\uB824 \uC785\uAC00\uC5D0 \uC9D3\uAD82\uC740 \uBBF8\uC18C\uB97C
      \uB760\uBA70 \uD65C\uC2DC\uC704\uB97C \uD33D\uD33D\uD558\uAC8C \uB2F9\uACBC\uB2E4.
      \uADF8\uB140\uC758 \uB208\uB3D9\uC790\uB294 \uC774\uBBF8 \uC624\uD06C \uC655\uC758
      \uC721\uC911\uD55C \uADFC\uC721 \uC0AC\uC774, \uCE58\uBA85\uC801\uC778 \uBE48\uD2C8\uC744
      \uD6D1\uACE0 \uC788\uC5C8\uB2E4.\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: 2
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uB2E4\uC774\uB098"
    text: "\"\uC640\uD558\uD558, \uC800 \uADFC\uC721 \uC880 \uBD10! \uAE30\uC0AC\uB2E8\uC7A5\uB2D8,
      \uC544\uBB34\uB9AC \uD2BC\uD2BC\uD574\uB3C4 \uC800 \uB369\uCE58\uB97C \uD63C\uC790
      \uBC84\uD2F0\uAE34 \uD798\uB4E4\uACA0\uB294\uB370? \uB0B4\uAC00 \uC2DC\uC120\uC744
      \uB04C \uD14C\uB2C8\uAE4C \uD2C8\uC744 \uBD10\uC11C \uD655\uC2E4\uD558\uAC8C
      \uCC14\uB7EC\uBC84\uB9AC\uB77C\uACE0!\"\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: " \uC5D8\uB9AC\uC57C\uB294 \uAC80 \uC190\uC7A1\uC774\uB97C \uBD80\uC11C\uC9C8
      \uB4EF \uAF49 \uC950\uBA70 \uAC70\uAD6C \uC55E\uC5D0 \uC130\uB2E4. \uADF8\uC758
      \uB4F1 \uB4A4\uB85C \uB3D9\uB8CC\uB4E4\uC758 \uB9C8\uB825\uACFC \uC2E0\uC131\uD55C
      \uAE30\uC6B4\uC774 \uBAA8\uC5EC\uB4DC\uB294 \uAC83\uC774 \uB290\uAEF4\uC84C\uB2E4.\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uBD80\uD0C1\uD569\uB2C8\uB2E4, \uB2E4\uC774\uB098 \uC528! \uC138\uC2E4\uB9AC\uC544
      \uB2D8, \uCE58\uC720\uC758 \uAE30\uB3C4\uB97C \uBA48\uCD94\uC9C0 \uB9C8\uC2ED\uC2DC\uC624.
      \uC18C\uD53C\uC544, \uD654\uB825\uC744 \uC9D1\uC911\uD574 \uC8FC\uC138\uC694!
      \uAC00\uACA0\uC2B5\uB2C8\uB2E4!\"\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC5D8\uB9AC\uC57C\uAC00 \uB300\uC9C0\uB97C \uBC15\uCC28\uACE0 \uB098\uAC00
      \uC624\uD06C \uC655\uC758 \uBB35\uC9C1\uD55C \uB0B4\uB9AC\uCE58\uAE30\uB97C
      \uAC80\uC73C\uB85C \uBC1B\uC544\uB0C8\uB2E4. \"\uCFE0\uAC15\u2014!\" \uD558\uB294
      \uAD49\uC74C\uACFC \uD568\uAED8 \uBD88\uAF43\uC774 \uD280\uC5C8\uACE0, \uADF8\uAC00
      \uAC70\uAD6C\uC758 \uAD11\uAE30\uB97C \uC815\uBA74\uC5D0\uC11C \uACAC\uB38C\uB0B4\uB294
      \uC0AC\uC774 \uB2E4\uC774\uB098\uC758 \uADF8\uB9BC\uC790 \uAC19\uC740 \uC6C0\uC9C1\uC784\uACFC
      \uC18C\uD53C\uC544\uC758 \uB0A0\uCE74\uB85C\uC6B4 \uB9C8\uBC95\uC774 \uC624\uD06C
      \uC655\uC758 \uBE48\uD2C8\uC744 \uC0AC\uC815\uC5C6\uC774 \uD30C\uACE0\uB4E4\uAE30
      \uC2DC\uC791\uD588\uB2E4.\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
