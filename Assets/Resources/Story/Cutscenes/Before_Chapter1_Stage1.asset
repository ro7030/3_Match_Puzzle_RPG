    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 626432301376018660, guid: dac69674361503b4ea7bd6ee6855dba4, type: 3}
    speakerName: 
    text: "\uD55C\uB54C \uC694\uC815\uB4E4\uC774 \uAC70\uB2D0\uB358 '\uC544\uB974\uCE74\uB514\uC544'\uC758
      \uC790\uBD80\uC2EC, \uB9C8\uBB3C\uC758 \uC232\uC740 \uBE44\uBA85\uC870\uCC28
      \uC9C0\uB974\uC9C0 \uBABB\uD55C \uCC44 \uC8FD\uC5B4\uAC00\uACE0 \uC788\uC5C8\uB2E4.
      \uBCFC\uCF00\uC778\uC774 \uD1A0\uD574\uB0B8 \uBD80\uC815\uD55C \uB9C8\uB825\uC740
      \uD718\uD669\uCC2C\uB780\uD588\uB358 \uCD08\uB85D\uC758 \uC0DD\uBA85\uB825\uC744
      \uC7BF\uBE5B\uC73C\uB85C \uBB3C\uB4E4\uC600\uB2E4."
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uBC1C\uC744 \uB0B4\uB514\uB51C \uB54C\uB2E4\uB9C8 \uB9C8\uB978 \uB098\uBB47\uAC00\uC9C0\uAC00
      \uBF08\uB9C8\uB514\uCC98\uB7FC \uBC14\uC2A4\uB77C\uC9C4\uB2E4. \uBD88\uCF8C\uD55C
      \uD669\uB958 \uB0C4\uC0C8\uC640 \uB048\uC801\uD55C \uACF5\uAE30... \uC544\uB974\uCE74\uB514\uC544 
      \uAD11\uC7A5\uC758 \uCC38\uC0C1\uC774 \uC774\uACF3\uAE4C\uC9C0 \uBED7\uCCD0
      \uC788\uC5C8\uB2E4.'\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uBAA8\uB450 \uACBD\uACC4\uD558\uC2ED\uC2DC\uC624. \uC232\uC758 \uAE30\uC6B4\uC774
      \uD3C9\uC18C\uC640 \uB2E4\uB985\uB2C8\uB2E4. \uC0DD\uBA85\uCCB4\uB4E4\uC774...
      \uC6B0\uB9AC\uB97C \uC801\uB300\uD558\uACE0 \uC788\uC5B4\uC694.\"\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: 2
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uB2E4\uC774\uB098"
    text: "\"\uC9C4\uC9DC\uB124. \uC6D0\uB798 \uC5EC\uAE30 \uC2AC\uB77C\uC784\uB4E4\uC740
      \uB9D0\uB791\uB9D0\uB791\uD574\uC11C \uADC0\uC5EC\uC6E0\uB294\uB370... \uC800
      \uBD89\uC740 \uB208 \uC880 \uBD10. \uC644\uC804\uD788 \uBBF8\uCCE4\uC5B4! 300\uB144
      \uB118\uAC8C \uC0B4\uBA74\uC11C \uC774\uB7F0 \uBD88\uCF8C\uD55C \uB9C8\uB825\uC740
      \uCC98\uC74C\uC774\uC57C.\"\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: 1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC18C\uD53C\uC544"
    text: "\"\uB2F9\uC5F0\uD558\uC8E0. \uC804\uC124 \uC18D \uC6A9\uC758 \uB9C8\uB825\uC774\uB2C8\uAE4C\uC694.
      \uBD84\uC11D\uD560 \uAC00\uCE58\uB294 \uC788\uACA0\uC9C0\uB9CC... \uC77C\uB2E8
      \uB0B4 \uC18C\uC911\uD55C \uB9C8\uBC95\uC11C\uC5D0 \uC800 \uC810\uC561\uC774
      \uBB3B\uAE30 \uC804\uC5D0 \uCC98\uB9AC\uD558\uB294 \uAC8C \uC88B\uACA0\uB124\uC694.\"\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
