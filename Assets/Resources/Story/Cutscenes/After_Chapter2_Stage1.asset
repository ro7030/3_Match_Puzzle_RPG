  m_Script: {fileID: 11500000, guid: d5ebec344a07c0b4fac788942570856a, type: 3}
  m_Name: After_Chapter2_Stage1
  m_EditorClassIdentifier: Assembly-CSharp::Story.CutsceneData
  cutsceneId: 
  nextSceneName: MapScene
  isPrologueMode: 1
  clearSaveOnComplete: 0
  dialogueLines:
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC18C\uD53C\uC544\uAC00 \uACE0\uC11C\uB97C \uD3BC\uCE58\uC790 \uD478\uB978
      \uB9C8\uB825\uC774 \uD3ED\uBC1C\uD558\uBA70 \uD574\uACE8 \uBCD1\uC0AC\uB4E4\uC758
      \uBA38\uB9AC \uC704\uB85C \uC3DF\uC544\uC84C\uB2E4. \uAD11\uC5ED \uB9C8\uBC95\uC758
      \uCDA9\uACA9\uC5D0 \uD574\uACE8\uB4E4\uC758 \uAD6C\uC870\uAC00 \uBB34\uB108\uC9C0\uBA70
      \uBE44\uB85C\uC18C \uBA3C\uC9C0\uAC00 \uB418\uC5B4 \uD769\uC5B4\uC84C\uB2E4.\r\n"
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uBCF5\uB3C4 \uAE4A\uC219\uC774 \uB4E4\uC5B4\uAC08\uC218\uB85D \uBC14\uB2E5\uC758
      \uBB38\uC591\uC774 \uAE30\uAD34\uD558\uAC8C \uB4A4\uD2C0\uB9B0\uB2E4. \uBCBD\uBA74\uC5D0\uC11C\uB294
      \uD654\uC0B4\uCD09\uC774 \uBC88\uB729\uC774\uACE0, \uBC14\uB2E5\uC740 \uC5B8\uC81C\uB4E0
      \uAEBC\uC9C8 \uB4EF \uC704\uD0DC\uB86D\uB2E4'"
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC5D8\uB9AC\uC57C\uB294 \uB0A0\uC544\uC624\uB294 \uD654\uC0B4\uB4E4\uC744
      \uCE7C\uB85C \uCCD0\uB0B4\uBA70"
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uD568\uC815\uC774 \uB108\uBB34 \uB9CE\uC2B5\uB2C8\uB2E4! \uD55C \uAC78\uC74C
      \uB0B4\uB51B\uAE30\uAC00 \uBB34\uC12D\uAD70\uC694."
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
  - characterId: 2
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uB2E4\uC774\uB098"
    text: " \"\uC7A0\uAE50, \uBA48\uCDB0! \uBC1C\uBC11 \uC18C\uB9AC\uAC00 \uB2EC\uB77C.
      \uC5EC\uAE34 \uD568\uC815\uC774\uC57C, \uC67C\uCABD\uC73C\uB85C \uB6F0\uC5B4!\""
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uB2E4\uC774\uB098\uC758 \uC608\uB9AC\uD55C \uC9C1\uAC10\uC774 \uBE5B\uC744
      \uBC1C\uD588\uB2E4. \uADF8\uB140\uC758 \uC9C0\uC2DC\uC5D0 \uB530\uB77C \uC77C\uD589\uC774
      \uBAB8\uC744 \uB0A0\uB9AC\uC790, \uBC29\uAE08 \uC11C \uC788\uB358 \uC790\uB9AC\uC5D0
      \uAC70\uB300\uD55C \uAC00\uC2DC \uD568\uC815\uC774 \uC19F\uC544\uC62C\uB790\uB2E4.\r\n"
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uC18C\uD53C\uC544\uC758 \uD574\uBC15\uD55C \uC9C0\uC2DD\uACFC \uB2E4\uC774\uB098\uC758
      \uBCF8\uB2A5\uC801\uC778 \uAC10\uAC01. \uC774 \uB458\uC758 \uD611\uB825\uC774
      \uC544\uB2C8\uC5C8\uB2E4\uBA74 \uC6B0\uB9AC\uB294 \uC774 \uBBF8\uB85C \uC18D\uC5D0\uC11C
      \uD3C9\uC0DD \uD5E4\uB9F8\uC744\uC9C0\uB3C4 \uBAA8\uB978\uB2E4. \uAC01\uAE30
      \uB2E4\uB978 \uC7AC\uB2A5\uC774 \uBAA8\uC5EC \uD558\uB098\uC758 \uAE38\uC774
      \uB9CC\uB4E4\uC5B4\uC9C0\uACE0 \uC788\uC5C8\uB2E4.'"
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
  - characterId: 1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC18C\uD53C\uC544"
    text: "\"\uD765, \uBAA8\uD5D8\uAC00 \uC9EC\uBC25\uC740 \uD5DB\uBA39\uC740 \uAC8C
      \uC544\uB2C8\uB124\uC694. \uC774 \uBB38\uC591\uB4E4\uC740 \uACE0\uB300 \uC655\uAD6D\uC758
      \uBD09\uC778\uC220\uC774\uC5D0\uC694. \uC81C\uAC00 \uAE38\uC744 \uC77D\uC744
      \uD14C\uB2C8 \uB2E4\uC774\uB098 \uC528\uB294 \uD568\uC815\uC758 \uAE30\uCC99\uC744
      \uC0B4\uD3B4\uC694.\""
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
