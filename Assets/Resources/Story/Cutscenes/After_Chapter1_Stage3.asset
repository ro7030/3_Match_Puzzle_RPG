  m_Script: {fileID: 11500000, guid: d5ebec344a07c0b4fac788942570856a, type: 3}
  m_Name: After_Chapter1_Stage3
  m_EditorClassIdentifier: Assembly-CSharp::Story.CutsceneData
  cutsceneId: 
  nextSceneName: MapScene
  isPrologueMode: 1
  clearSaveOnComplete: 0
  dialogueLines:
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uB05D\uB0AC\uAD70... \uC232\uC758 \uD3ED\uAD70\uC870\uCC28 \uC6A9\uC758
      \uB9C8\uB825 \uC55E\uC5D0\uC11C\uB294 \uAF2D\uB450\uAC01\uC2DC\uC77C \uBFD0\uC774\uC5C8\uB098.\""
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC138\uC2E4\uB9AC\uC544\uAC00 \uC9C0\uCE5C \uAE30\uC0C9\uC774 \uC5ED\uB825\uD55C
      \uC5D8\uB9AC\uC57C\uC5D0\uAC8C \uB2E4\uAC00\uAC14\uB2E4. \uADF8\uB140\uB294
      \uAC71\uC815\uC2A4\uB7EC\uC6B4 \uB208\uBE5B\uC73C\uB85C \uADF8\uC758 \uCC22\uACA8\uC9C4
      \uAC11\uC637 \uC0AC\uC774\uB85C \uD750\uB974\uB294 \uD53C\uB97C \uBC14\uB77C\uBCF4\uB354\uB2C8,
      \uAC00\uB0D8\uD508 \uC190\uC744 \uBED7\uC5B4 \uC5D8\uB9AC\uC57C\uC758 \uC5B4\uAE68
      \uC704\uC5D0 \uC0B4\uD3EC\uC2DC \uC5B9\uC5C8\uB2E4. \uCC28\uAC00\uC6B4 \uAE08\uC18D
      \uAC11\uC637 \uB108\uBA38\uB85C \uADF8\uB140\uC758 \uC628\uAE30\uAC00 \uB9C8\uBC95\uCC98\uB7FC
      \uC2A4\uBA70\uB4E4\uC5C8\uB2E4.\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: 3
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC138\uC2E4\uB9AC\uC544"
    text: "\"\uACE0\uC0DD\uD558\uC168\uC5B4\uC694, \uC5D8\uB9AC\uC57C \uB2D8. \uC0DD\uAC01\uBCF4\uB2E4
      \uC0C1\uCC98\uAC00 \uAE4A\uB124\uC694. \uC7A0\uC2DC\uB9CC \uC2E4\uB840\uD560\uAC8C\uC694.\"\r\n"
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC138\uC2E4\uB9AC\uC544\uC758 \uC190\uB05D\uC5D0\uC11C \uD53C\uC5B4\uC624\uB978
      \uB208\uBD80\uC2E0 \uBC31\uC0C9\uAD11\uC774 \uC5D8\uB9AC\uC57C\uC758 \uC804\uC2E0\uC744
      \uBD80\uB4DC\uB7FD\uAC8C \uAC10\uC2F8 \uC548\uC558\uB2E4. \uC6B1\uC2E0\uAC70\uB9AC\uB358
      \uD1B5\uC99D\uC774 \uC53B\uC740 \uB4EF \uC0AC\uB77C\uC9C0\uACE0, \uCC22\uACA8
      \uB098\uAC14\uB358 \uC0B4\uC810\uC774 \uAE30\uC801\uCC98\uB7FC \uB9DE\uBB3C\uB9AC\uBA70
      \uC0C8\uC0B4\uC774 \uB3CB\uC544\uB0AC\uB2E4. \uB530\uC2A4\uD55C \uBD04\uBCD5
      \uAC19\uC740 \uCE58\uC720\uC758 \uAE30\uC6B4\uC5D0 \uC5D8\uB9AC\uC57C\uC758
      \uAE34\uC7A5\uB41C \uADFC\uC721\uC774 \uC11C\uC11C\uD788 \uD480\uB824\uAC14\uB2E4."
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: 1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC18C\uD53C\uC544"
    text: "\"\uAC10\uC0C1\uC5D0 \uC816\uC5B4 \uC788\uC744 \uC2DC\uAC04 \uC5C6\uC5B4\uC694.
      \uBCF4\uC138\uC694, \uC800\uAE30\uC608\uC694. \uC232\uC758 \uB05D\uC790\uB77D\uC5D0
      \uC228\uACA8\uC838 \uC788\uB358 '\uADF8\uACF3' \uB9D0\uC774\uC5D0\uC694.\""
    backgroundSprite: {fileID: 5742503089790683256, guid: b18bfd5a245b49348bde36d021bce4b3, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC18C\uD53C\uC544\uC758 \uC9C0\uD321\uC774\uAC00 \uAC00\uB9AC\uD0A8 \uACF3\uC5D0\uB294
      \uC2DC\uB4E0 \uB098\uBB34\uB4E4\uC774 \uB9C8\uCE58 \uAC70\uB300\uD55C \uAC10\uC625\uC758
      \uCC3D\uC0B4\uCC98\uB7FC \uC5BD\uD600 \uC788\uC5C8\uB2E4. \uADF8 \uAE30\uAD34\uD55C
      \uC232\uC758 \uC7A5\uB9C9\uC774 \uAC77\uD788\uC790, \uC555\uB3C4\uC801\uC778
      \uD06C\uAE30\uC758 \uC74C\uC0B0\uD55C \uB3CC\uBB38\uC774 \uBAA8\uC2B5\uC744
      \uB4DC\uB7EC\uB0C8\uB2E4. \uC804\uC124 \uC18D\uC5D0\uB098 \uC874\uC7AC\uD55C\uB2E4\uB358
      '\uACE0\uB300 \uC720\uC801\uC9C0'\uC600\uB2E4."
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 2
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uB2E4\uC774\uB098"
    text: "\"\uC640... \uBAA8\uD5D8\uAC00 \uC0DD\uD65C \uC218\uBC31 \uB144 \uB9CC\uC5D0
      \uC774\uB7F0 \uACF3\uC740 \uCC98\uC74C \uBD10. \uC785\uAD6C\uBD80\uD130 \uD574\uACE8\uB4E4\uC774
      \uC800\uB807\uAC8C \uB300\uB193\uACE0 \uC9C0\uD0A4\uACE0 \uC788\uB294 \uAC78
      \uBCF4\uB2C8, \uD658\uC601 \uD30C\uD2F0\uAC00 \uAF64 \uAC70\uCC3D\uD558\uACA0\uB294\uB370?
      \uC774\uAC70 \uD53C\uAC00 \uB053\uB294\uAC78!\"\r\n"
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uB2E4\uC774\uB098\uB294 \uAE34\uC7A5\uC744 \uD138\uC5B4\uB0B4\uB824\uB294
      \uB4EF \uD65C\uC744 \uAC00\uBCCD\uAC8C \uD718\uB450\uB974\uBA70 \uC720\uC801\uC758
      \uC785\uAD6C\uB97C \uC751\uC2DC\uD588\uB2E4. \uCC28\uAC00\uC6B4 \uC11D\uC870
      \uAC74\uBB3C\uC758 \uD55C\uAE30\uAC00 \uC232\uC758 \uB205\uB205\uD55C \uC5F4\uAE30\uB97C
      \uBC00\uC5B4\uB0B4\uBA70 \uC77C\uD589\uC758 \uD53C\uBD80\uC5D0 \uC18C\uB984\uC744
      \uB3CB\uAC8C \uD588\uB2E4"
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC18C\uD53C\uC544"
    text: "'\uC5B4\uBA38\uB2C8\uAC00 \uC77D\uC5B4\uC8FC\uB358 \uB0A1\uC740 \uB3D9\uD654
      \uC18D\uC5D0\uC11C, \uC601\uC6C5\uB4E4\uC774 \uB450 \uBC88\uC9F8\uB85C \uBC1C\uC744
      \uB4E4\uC600\uB358 \uC2DC\uB828\uC758 \uC7A5\uC18C. \uB208\uC55E\uC758 \uAC70\uB300\uD55C
      \uC11D\uBB38\uC740 \uB9C8\uCE58 \uAC70\uB300\uD55C \uAD34\uBB3C\uC758 \uC544\uAC00\uB9AC\uCC98\uB7FC
      \uC6B0\uB9AC\uB97C \uC9D1\uC5B4\uC0BC\uD0AC \uC900\uBE44\uB97C \uD558\uACE0
      \uC788\uB2E4.'"
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC5D8\uB9AC\uC57C\uB294 \uCE58\uC720\uB41C \uC5B4\uAE68\uB97C \uAC00\uBCCD\uAC8C
      \uB3CC\uB9AC\uBA70 \uB2E4\uC2DC\uAE08 \uAC80\uC744 \uACE0\uCCD0 \uC950\uC5C8\uB2E4.
      \uADF8\uC758 \uB208\uB3D9\uC790\uC5D0\uB294 \uC720\uC801\uC758 \uD55C\uAE30\uBCF4\uB2E4
      \uB354 \uB0A0\uCE74\uB85C\uC6B4 \uACB0\uC758\uAC00 \uC11C\uB824 \uC788\uC5C8\uB2E4.\r\n"
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uC774\uC81C\uBD80\uD130\uAC00 \uC9C4\uC9DC \uC2DC\uC791\uC785\uB2C8\uB2E4.
      \uB2E4\uB4E4 \uC815\uC2E0 \uBC14\uC9DD \uCC28\uB9AC\uC2ED\uC2DC\uC624.\""
    backgroundSprite: {fileID: -7224703372054014782, guid: 5ec528bb620e6f14ab0bf6da0403eb88, type: 3}
