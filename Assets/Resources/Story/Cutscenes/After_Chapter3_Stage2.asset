  m_Script: {fileID: 11500000, guid: d5ebec344a07c0b4fac788942570856a, type: 3}
  m_Name: After_Chapter3_Stage2
  m_EditorClassIdentifier: Assembly-CSharp::Story.CutsceneData
  cutsceneId: 
  nextSceneName: MapScene
  isPrologueMode: 1
  clearSaveOnComplete: 0
  dialogueLines:
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\"\uCE58\uC774\uC775\u2014!\" \uC18C\uD53C\uC544\uC640 \uC138\uC2E4\uB9AC\uC544\uC758
      \uD569\uB3D9 \uACF5\uACA9\uC774 \uC774\uD504\uB9AC\uD2B8\uC758 \uAC00\uC2B4
      \uC911\uC559, \uBD89\uAC8C \uBE5B\uB098\uB358 \uD575\uC744 \uC815\uD655\uD788
      \uD0C0\uACA9\uD588\uB2E4. \uAC70\uB300\uD55C \uD654\uC5FC\uC758 \uC721\uCCB4\uAC00
      \uBE44\uBA85\uACFC \uD568\uAED8 \uC0B0\uC0B0\uC870\uAC01 \uB09C\uB2E4."
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC774\uD504\uB9AC\uD2B8\uB294 \uC18C\uBA78\uD574\uAC00\uB294 \uC640\uC911\uC5D0\uB3C4
      \uC800\uC8FC \uC11E\uC778 \uC608\uC5B8\uC744 \uBA48\uCD94\uC9C0 \uC54A\uC558\uB2E4.
      \uB188\uC758 \uD615\uD0DC\uAC00 \uD750\uB9BF\uD574\uC9C0\uBA70 \uB9C8\uC9C0\uB9C9
      \uBD88\uAF43\uC774 \uC0AC\uADF8\uB77C\uB4E4\uC5C8\uB2E4.\r\n"
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: -6702937843246533677, guid: 8f27ca58b55c595408a8e9d94ab8ea73, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC774\uD504\uB9AC\uD2B8"
    text: "\"\uD06C\uC73D... \uD558\uC9C0\uB9CC... \uC78A\uC9C0 \uB9C8\uB77C... \uC8FC\uC778\uB2D8\uC758
      \uBD84\uB178\uB294... \uC774\uBBF8... \uC784\uACC4\uC810\uC744 \uB118\uC5C8\uB2E4...
      \uB108\uD76C\uB294 \uACB0\uCF54... \uC0B4\uC544\uB0A8\uC9C0 \uBABB\uD560......\"\r\n"
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC774\uD504\uB9AC\uD2B8\uAC00 \uC0AC\uB77C\uC9C4 \uC790\uB9AC\uC5D0 \uB0A8\uC740
      \uAC83\uC740 \uD0C0 \uB4E4\uC5B4\uAC00\uB294 \uC5F4\uAE30\uBFD0\uC774\uC5C8\uB2E4.
      \uC2B9\uB9AC\uD588\uC9C0\uB9CC, \uADF8 \uB300\uAC00\uB294 \uAC00\uD639\uD588\uB2E4.
      \uC18C\uD53C\uC544\uB294 \uC9C0\uD321\uC774\uB97C \uC9C0\uC9C0\uB300 \uC0BC\uC544
      \uBE44\uD2C0\uAC70\uB9AC\uB354\uB2C8 \uC774\uB0B4 \uD798\uC5C6\uC774 \uBB34\uB98E\uC744
      \uAFC7\uC5C8\uB2E4."
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: 1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC18C\uD53C\uC544"
    text: "\"\uD558\uC544... \uD558\uC544... \uB9C8\uB825\uC774... \uD55C \uBC29\uC6B8\uB3C4
      \uC548 \uB0A8\uC558\uC5B4. \uC774\uC81C... \uC190\uAC00\uB77D \uD558\uB098
      \uAE4C\uB531\uD560 \uD798\uB3C4...\""
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uB2E4\uC774\uB098 \uC5ED\uC2DC \uC2DC\uCEE4\uBA53\uAC8C \uD0C0\uBC84\uB9B0
      \uC637\uC790\uB77D\uC744 \uD5C8\uB9DD\uD558\uAC8C \uBC14\uB77C\uBCF4\uB2E4\uAC00
      \uBC14\uB2E5\uC5D0 \uD138\uC11D \uC8FC\uC800\uC549\uC558\uB2E4. \uD3C9\uC18C\uC758
      \uC7A5\uB09C\uAE30 \uC5B4\uB9B0 \uB208\uBE5B\uC740 \uC628\uB370\uAC04\uB370\uC5C6\uC5C8\uB2E4."
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: 2
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uB2E4\uC774\uB098"
    text: "\"\uB098\uB3C4... \uD55C\uACC4\uC57C. \uD65C\uC2DC\uC704\uB97C \uB2F9\uAE38
      \uC190\uAC00\uB77D\uC5D0 \uAC10\uAC01\uC774 \uC5C6\uC5B4. \uC9C4\uC9DC... \uC5EC\uAE30\uC11C
      \uB05D\uC778\uAC00 \uBD10.\""
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: 1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC5D8\uB9AC\uC57C\uB294 \uC774\uBBF8 \uAE08\uC774 \uAC00\uBC84\uB9B0
      \uCE7C\uC744 \uB0B4\uB824\uB193\uACE0, \uBE44\uD2C0\uAC70\uB9AC\uB294 \uB3D9\uB8CC\uB4E4\uC744
      \uD558\uB098\uB458\uC529 \uBD80\uCD95\uD574 \uC77C\uC73C\uCF30\uB2E4. \uADF8\uC758
      \uBAA9\uC18C\uB9AC\uC870\uCC28 \uAC08\uB77C\uC838 \uC788\uC5C8\uB2E4."
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uD3EC\uAE30\uD558\uC9C0 \uB9C8\uC138\uC694. \uAC70\uC758 \uB2E4 \uC654\uC2B5\uB2C8\uB2E4.
      \uC774\uC81C... \uC800 \uBB38\uB9CC \uB118\uC73C\uBA74...\""
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC138\uC2E4\uB9AC\uC544\uB294 \uB5A8\uB9AC\uB294 \uC190\uC73C\uB85C \uBAA8\uB450\uC758
      \uC0C1\uCC98\uB97C \uCE58\uC720\uD558\uB824 \uC560\uC37C\uB2E4. \uADF8\uB7EC\uB098
      \uADF8\uB140\uC758 \uC190\uB05D\uC5D0\uC11C \uD53C\uC5B4\uC624\uB974\uB358
      \uBE5B\uC740 \uC774\uB0B4 \uD798\uC5C6\uC774 \uC0AC\uADF8\uB77C\uC84C\uB2E4.
      \uADF8\uB140\uB294 \uBBF8\uC548\uD568\uC774 \uC11C\uB9B0 \uCC3D\uBC31\uD55C
      \uBBF8\uC18C\uB97C \uC9C0\uC73C\uBA70 \uC77C\uD589\uC744 \uBC14\uB77C\uBCF4\uC558\uB2E4"
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: 3
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC138\uC2E4\uB9AC\uC544"
    text: "\"\uC8C4\uC1A1\uD574\uC694... \uC2E0\uC131\uB825\uC774... \uB354\uB294
      \uC751\uB2F5\uD558\uC9C0 \uC54A\uC544\uC694. \uD558\uC9C0\uB9CC... \uB05D\uAE4C\uC9C0
      \uD568\uAED8\uD558\uACA0\uC5B4\uC694.\""
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uB3D9\uB8CC\uB4E4\uC758 \uB208\uC5D0 \uC9D9\uC740 \uD53C\uB85C\uC640
      \uC808\uB9DD\uC774 \uC11C\uB824 \uC788\uB2E4. \uB098 \uC5ED\uC2DC \uD3D0\uBD80\uAC00
      \uD0C0 \uB4E4\uC5B4\uAC00\uB294 \uACE0\uD1B5\uC5D0 \uB2F9\uC7A5\uC774\uB77C\uB3C4
      \uC4F0\uB7EC\uC9C0\uACE0 \uC2F6\uB2E4. \uD558\uC9C0\uB9CC... \uC694\uC0C8\uC758
      \uC2EC\uC7A5\uBD80\uC5D0\uC11C \uB290\uAEF4\uC9C0\uB294 \uAC70\uB300\uD55C
      \uBC15\uB3D9\uC774 \uC6B0\uB9AC\uB97C \uBD80\uB974\uACE0 \uC788\uB2E4.'"
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC694\uC0C8\uC758 \uB9C8\uC9C0\uB9C9 \uAC70\uB300 \uBB38\uC774 \uC911\uD6C4\uD55C
      \uC18C\uB9AC\uB97C \uB0B4\uBA70 \uC5F4\uB9AC\uACE0, \uADF8 \uB108\uBA38 \uC5B4\uB460
      \uC18D\uC5D0\uC11C \uAC70\uB300\uD55C \uB450 \uB208\uC774 \uBC88\uB729\uC778\uB2E4."
    backgroundSprite: {fileID: 1471107899431857183, guid: 78265d5069f9e1843b5c57edd43e2a75, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uB4DC\uB514\uC5B4... \uB9C8\uC8FC\uD558\uAC8C \uB410\uAD70.\""
    backgroundSprite: {fileID: 1471107899431857183, guid: 78265d5069f9e1843b5c57edd43e2a75, type: 3}
