  dialogueLines:
  - characterId: -1
    characterSpriteOverride: {fileID: 7490447831796998959, guid: 7a59d90d17fc0d14ba07780873533399, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC232\uC758 \uC5F4\uAE30\uAC00 \uCC44 \uAC00\uC2DC\uAE30\uB3C4 \uC804,
      \uC77C\uD589\uC744 \uB9DE\uC774\uD55C \uAC83\uC740 \uC11C\uB298\uD55C \uC8FD\uC74C\uC758
      \uD55C\uAE30\uC600\uB2E4. \uC218\uBC31 \uB144\uAC04 \uC815\uC801 \uC18D\uC5D0
      \uC7A0\uB4E4\uC5B4 \uC788\uB358 \uC720\uC801\uC758 \uBC14\uB2E5\uC5D0\uC11C
      \uB35C\uCEE5\uAC70\uB9AC\uB294 \uBF08\uB9C8\uB514 \uC18C\uB9AC\uAC00 \uC6B8\uB824
      \uD37C\uC84C\uB2E4."
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uAC80\uC744 \uD718\uB458\uB7EC \uB188\uC758 \uAC00\uC2B4\uD30D\uC744
      \uAC08\uB790\uB2E4. \uD558\uC9C0\uB9CC \uD3C9\uC18C\uC640 \uAC19\uC740 \uD0C0\uACA9\uAC10\uC774
      \uC5C6\uB2E4. \uC798\uB824 \uB098\uAC04 \uBF08\uB4E4\uC740 \uB9C8\uCE58 \uC790\uC11D\uC774\uB77C\uB3C4
      \uBD99\uC740 \uB4EF \uAE08\uC138 \uC81C\uC790\uB9AC\uB97C \uCC3E\uC544\uAC00\uBA70
      \uB2E4\uC2DC\uAE08 \uCC3D\uC744 \uCE58\uCF1C\uB4E4\uC5C8\uB2E4.'"
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uCE58\uBA85\uC0C1\uC744 \uC785\uD614\uB294\uB370\uB3C4 \uC4F0\uB7EC\uC9C0\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4! \uBF08\uB9C8\uB514 \uC0AC\uC774\uB85C \uAC80\uC774
      \uADF8\uB0E5 \uBE60\uC838\uB098\uAC00\uB294 \uAE30\uBD84\uC774\uC5D0\uC694!\"\r\n"
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 2
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uB2E4\uC774\uB098"
    text: " \"\uB0B4 \uD654\uC0B4\uB3C4 \uC18C\uC6A9\uC5C6\uC5B4. \uC0B4\uC810\uC774
      \uC5C6\uC73C\uB2C8 \uBC15\uD788\uC9C8 \uC54A\uC796\uC544! \uC57C, \uAF2C\uB9C8
      \uB300\uB9C8\uBC95\uC0AC! \uC5B4\uB5BB\uAC8C \uC880 \uD574\uBD10!\""
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
  - characterId: 1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC18C\uD53C\uC544"
    text: "\"\uB204\uAC00 \uAF2C\uB9C8\uB77C\uB294 \uAC70\uC608\uC694? \uBB34\uC2DD\uD558\uAC8C
      \uD798\uC73C\uB85C\uB9CC \uBC00\uC5B4\uBD99\uC774\uB2C8\uAE4C \uADF8\uB807\uC8E0.
      \uC800\uAC74 \uB9C8\uB825\uC73C\uB85C \uC5EE\uC778 \uC800\uC8FC\uBC1B\uC740
      \uC778\uD615\uC774\uC5D0\uC694. \uBF08 \uC790\uCCB4\uB97C \uAC00\uB8E8\uB85C
      \uB9CC\uB4E4\uC9C0 \uC54A\uC73C\uBA74 \uC18C\uC6A9\uC5C6\uB2E4\uACE0\uC694!\"\r\n"
    backgroundSprite: {fileID: -5470523992703632891, guid: 2148d6759b203ca4189753453881ffd9, type: 3}
