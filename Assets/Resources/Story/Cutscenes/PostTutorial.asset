%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d5ebec344a07c0b4fac788942570856a, type: 3}
  m_Name: PostTutorial
  m_EditorClassIdentifier: Assembly-CSharp::Story.CutsceneData
  cutsceneId: 
  nextSceneName: KingdomScene
  isPrologueMode: 1
  clearSaveOnComplete: 0
  dialogueLines:
  - characterId: -1
    speakerName: 
    text: "\uC5D8\uB9AC\uC57C\uB294 \uAD11\uC7A5\uC758 \uB9C8\uBB3C\uB4E4\uC744 \uCC98\uB9AC\uD55C
      \uD6C4 \uBC14\uB85C \uC655\uC2E4\uB85C \uD5A5\uD558\uC600\uB2E4."
    backgroundSprite: {fileID: 21300000, guid: 7b14c06381fb4ac44abbceef169aee82, type: 3}
  - characterId: -1
    speakerName: 
    text: "\uC5D8\uB9AC\uC57C\uB294 \uC5B4\uAE68\uB97C \uD06C\uAC8C \uB4E4\uC369\uC774\uBA70
      \uAC00\uC05C \uC228\uC744 \uBAB0\uC544\uC26C\uC5C8\uB2E4. \uAC11\uC637 \uC0AC\uC774\uB85C
      \uD750\uB974\uB294 \uB540\uBC29\uC6B8\uC774 \uADF8\uC758 \uAE34\uBC15\uD588\uB358
      \uC0AC\uD22C\uB97C \uC99D\uBA85\uD558\uACE0 \uC788\uC5C8\uB2E4."
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: 0
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uBB34\uC0AC\uD558\uC2ED\uB2C8\uAE4C, \uD3D0\uD558!\""
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: 4
    speakerName: "\uC655"
    text: "\"\uC624, \uC5D8\uB9AC\uC57C! \uC9D0\uC740 \uBB34\uC0AC\uD558\uB2E4\uB9CC...
      \uBC16\uC758 \uC0C1\uD669\uC740 \uC5B4\uCC0C \uB41C \uAC83\uC778\uAC00?\"\r\n"
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: 0
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uC544\uC218\uB77C\uC7A5\uC785\uB2C8\uB2E4. \uC815\uCCB4\uBD88\uBA85\uC758
      \uAD70\uC138\uAC00 \uAD11\uC7A5\uC744 \uC810\uAC70\uD588\uACE0 \uB9C8\uBB3C\uB4E4\uC774
      \uB118\uCCD0\uB098\uACE0 \uC788\uC2B5\uB2C8\uB2E4. \uADF8\uB9AC\uACE0... \uD3D0\uD558,
      \uC81C \uAC80\uC774 \uC804\uC124 \uC18D \uC608\uC5B8\uCC98\uB7FC \uBE5B\uB098\uAE30
      \uC2DC\uC791\uD588\uC2B5\uB2C8\uB2E4. \uC544\uBB34\uB798\uB3C4... '\uBCFC\uCF00\uC778'\uC774
      \uB3CC\uC544\uC628 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.\"\r\n"
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: -1
    speakerName: 
    text: "\uC21C\uAC04, \uC655\uC758 \uC548\uC0C9\uC774 \uC885\uC787\uC7A5\uCC98\uB7FC
      \uCC3D\uBC31\uD558\uAC8C \uC9C8\uB838\uB2E4. \uC655\uC88C\uC758 \uD314\uAC78\uC774\uB97C
      \uC6C0\uCF1C\uC954 \uADF8\uC758 \uC190\uB4F1\uC5D0 \uD54F\uC904\uC774 \uB3CB\uC544\uB0AC\uB2E4."
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: 4
    speakerName: "\uC655"
    text: "\"\uC804\uC124\uC774... \uC804\uC124\uB85C \uB05D\uB098\uC9C0 \uC54A\uC558\uB2E8
      \uB9D0\uC778\uAC00. \uADFC\uC704\uBCD1! \uB2F9\uC7A5 \uB9C8\uBC95 \uD559\uAD50\uC758
      \uC18C\uD53C\uC544, \uBAA8\uD5D8\uAC00 \uB2E4\uC774\uB098, \uADF8\uB9AC\uACE0
      \uC131\uB140 \uC138\uC2E4\uB9AC\uC544\uB97C \uBD88\uB7EC\uC624\uB108\uB77C!\""
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: -1
    speakerName: 
    text: "\uC7A0\uC2DC \uD6C4, \uC138 \uBA85\uC758 \uC601\uC6C5\uB4E4\uC774 \uB3C4\uCC29\uD55C\uB2E4."
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: 4
    speakerName: "\uC655"
    text: "\"\uADF8\uB300\uB4E4\uB3C4 \uC774\uBBF8 \uB290\uAF08\uACA0\uC9C0. \uBB34\uAE30\uAC00
      \uB0B4\uBFDC\uB294 \uACF5\uBA85\uC744. \uC544\uB974\uCE74\uB514\uC544\uC758
      \uC6B4\uBA85\uC774 \uADF8\uB300\uB4E4\uC5D0\uAC8C \uB2EC\uB824\uC788\uB124.
      '\uBA78\uB8E1 \uC6D0\uC815\uB300'\uB85C\uC11C \uBCFC\uCF00\uC778\uC744 \uB2E4\uC2DC
      \uBD09\uC778\uD558\uACE0 \uC655\uAD6D\uC744 \uAD6C\uD574\uC8FC\uAC8C.\""
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: -1
    speakerName: 
    text: "\uC5D8\uB9AC\uC57C\uB294 \uD55C \uCE58\uC758 \uB9DD\uC124\uC784 \uC5C6\uC774
      \uAC80\uC744 \uBF51\uC544 \uB4E4\uC5B4 \uAC00\uC2B4 \uC55E\uC5D0 \uC138\uC6E0\uB2E4.
      \uC11C\uC2AC \uD37C\uB7F0 \uAC80\uB0A0\uC774 \uADF8\uC758 \uAD73\uAC74\uD55C
      \uACB0\uC758\uB97C \uBE44\uCD94\uC5C8\uB2E4."
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: 0
    speakerName: 
    text: "\"\uAE30\uC0AC\uB2E8\uC7A5 \uC5D8\uB9AC\uC57C, \uBAA9\uC228\uC744 \uBC14\uCCD0
      \uC655\uAD6D\uC744 \uC218\uD638\uD558\uACA0\uC2B5\uB2C8\uB2E4.\""
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: 0
    speakerName: 
    text: "\uC18C\uD53C\uC544\uB294 \uC9D0\uC9D3 \uB530\uBD84\uD558\uB2E4\uB294 \uD45C\uC815\uC73C\uB85C
      \uC9D9\uC740 \uBCF4\uB78F\uBE5B \uBA38\uB9AC\uCE74\uB77D\uC744 \uC190\uAC00\uB77D\uC73C\uB85C
      \uBC30\uBC30 \uAF2C\uC558\uB2E4."
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: 1
    speakerName: "\uC18C\uD53C\uC544"
    text: "\"\uD559\uC220\uC11C\uC5D0 \uC801\uD78C \uC804\uC124\uC744 \uC9C1\uC811
      \uD655\uC778\uD558\uAC8C \uB420 \uC904\uC774\uC57C... \uADC0\uCC2E\uAE34 \uD558\uC9C0\uB9CC,
      \uB300\uB9C8\uBC95\uC0AC \uC18C\uD53C\uC544\uC758 \uC2E4\uB825\uC744 \uBCF4\uC5EC\uC904
      \uB54C\uAC00 \uB41C \uBAA8\uC591\uC774\uB124\uC694.\""
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: -1
    speakerName: 
    text: "\uADF8 \uC606\uC5D0\uC11C \uB2E4\uC774\uB098\uB294 \uC775\uC219\uD55C
      \uC19C\uC528\uB85C \uB2E8\uAC80\uC744 \uACF5\uC911\uC5D0 \uB358\uC84C\uB2E4
      \uBC1B\uC73C\uBA70 \uB208\uC744 \uBC18\uC9DD\uC600\uB2E4."
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: 2
    speakerName: "\uB2E4\uC774\uB098"
    text: "\"\uC5ED\uC0AC\uC5D0 \uB0A8\uC744 \uBAA8\uD5D8\uC774\uB77C\uB2C8! \uB2E4\uC774\uB098
      \uB2D8\uC758 \uC774\uB984\uC774 \uC804\uAD6D\uC5D0 \uC6B8\uB824 \uD37C\uC9C0\uACA0\uB294\uAC78?
      \uB9E1\uACA8\uB2EC\uB77C\uACE0\uC694!\""
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: -1
    speakerName: 
    text: "\uC138\uC2E4\uB9AC\uC544\uAC00 \uACE4\uB780\uD558\uB2E4\uB294 \uB4EF \uBBF8\uAC04\uC744
      \uC0B4\uC9DD \uCC0C\uD478\uB9AC\uBA70 \uB450 \uC0AC\uB78C\uC744 \uD5A5\uD574
      \uBD80\uB4DC\uB7EC\uC6B4 \uBAA9\uC18C\uB9AC\uB85C \uC8FC\uC758\uB97C \uC8FC\uC5C8\uB2E4."
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: 3
    speakerName: 
    text: "\"\uB450 \uBD84, \uD3D0\uD558 \uC55E\uC785\uB2C8\uB2E4. \uC608\uC758\uB97C
      \uAC16\uCD94\uC138\uC694. ...\uC218\uB140 \uC138\uC2E4\uB9AC\uC544, \uC2E0\uAED8
      \uBC1B\uC740 \uCD95\uBCF5\uC73C\uB85C \uC655\uAD6D\uC744 \uAD6C\uD558\uB294
      \uB370 \uD798\uC744 \uBCF4\uD0DC\uACA0\uC2B5\uB2C8\uB2E4.\""
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
  - characterId: -1
    speakerName: 
    text: "\uAC01\uC790\uC758 \uC758\uC9C0\uB97C \uAC00\uC2B4\uC5D0 \uD488\uC740
      \uB124 \uC601\uC6C5\uC758 \uADF8\uB9BC\uC790\uAC00 \uC655\uC2E4\uC758 \uAE34
      \uBCF5\uB3C4\uB97C \uC9C0\uB098, \uC5B4\uB460\uC774 \uC9D9\uAC8C \uAE54\uB9B0
      \uB9C8\uBB3C\uC758 \uC232\uC744 \uD5A5\uD574 \uAE38\uAC8C \uBED7\uC5B4 \uB098\uAC14\uB2E4."
    backgroundSprite: {fileID: 21300000, guid: 70f18f71f40cb3f4ab09c28ee4ee0d69, type: 3}
