  m_Script: {fileID: 11500000, guid: d5ebec344a07c0b4fac788942570856a, type: 3}
  m_Name: Before_Chapter3_Stage2
  m_EditorClassIdentifier: Assembly-CSharp::Story.CutsceneData
  cutsceneId: 
  nextSceneName: BattleScene
  isPrologueMode: 1
  clearSaveOnComplete: 0
  dialogueLines:
  - characterId: -1
    characterSpriteOverride: {fileID: -6702937843246533677, guid: 8f27ca58b55c595408a8e9d94ab8ea73, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uB9AC\uC790\uB4DC\uB9E8\uB4E4\uC744 \uACA8\uC6B0 \uBB3C\uB9AC\uCE58\uACE0
      \uC804\uC9C4\uD558\uC790, \uC694\uC0C8\uC758 \uB9C8\uB825\uC744 \uBA39\uACE0
      \uC790\uB77C\uB09C \uC7AC\uC559\uC758 \uD654\uC2E0 '\uC774\uD504\uB9AC\uD2B8'\uAC00
      \uAC15\uB9BC\uD588\uB2E4. \uB188\uC758 \uC874\uC7AC\uB9CC\uC73C\uB85C\uB3C4
      \uC8FC\uBCC0\uC758 \uC0B0\uC18C\uAC00 \uD76C\uBC15\uD574\uC9C0\uBA70 \uC2DC\uC57C\uAC00
      \uC5B4\uC9C0\uB7EC\uC6CC\uC84C\uB2E4."
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: -6702937843246533677, guid: 8f27ca58b55c595408a8e9d94ab8ea73, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC55E\uC744 \uAC00\uB85C\uB9C9\uB294 \uC6A9\uC554 \uD3ED\uD3EC\uAC00
      \uAC08\uB77C\uC9C0\uBA70, \uADF8 \uC548\uC5D0\uC11C \uC628\uBAB8\uC774 \uD478\uB978
      \uBD88\uAF43\uC73C\uB85C \uC77C\uB801\uC774\uB294 \uB300\uC815\uB839 \uC774\uD504\uB9AC\uD2B8\uAC00
      \uC19F\uC544\uC624\uB978\uB2E4. \"\uCF70\uC544\uC544\uC559\u2014!\" \uB300\uAE30\uAC00
      \uC21C\uC2DD\uAC04\uC5D0 \uBC1C\uD654\uD558\uBA70 \uC5C4\uCCAD\uB09C \uD3ED\uD48D\uC774
      \uBAB0\uC544\uCE5C\uB2E4."
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: -6702937843246533677, guid: 8f27ca58b55c595408a8e9d94ab8ea73, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC774\uD504\uB9AC\uD2B8"
    text: "\"......\uAC00\uC18C\uB86D\uAD6C\uB098. \uD0C0\uC624\uB974\uB294 \uC5C5\uD654
      \uC18D\uC73C\uB85C \uC81C \uBC1C\uB85C \uAE30\uC5B4 \uB4E4\uC5B4\uC628 \uB098\uBC29\uB4E4\uC774\uC5EC.
      \uB108\uD76C\uC758 \uADF8 \uBCF4\uC798\uAC83\uC5C6\uB294 \uC601\uD63C\uC870\uCC28
      \uBCFC\uCF00\uC778 \uB2D8\uC758 \uC81C\uBB3C\uC774 \uB418\uAE30\uC5D4 \uB108\uBB34\uB3C4
      \uCC28\uAC11\uAD6C\uB098.\""
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uB188\uC758 \uBAA9\uC18C\uB9AC\uB294 \uC774 \uB113\uC740 \uACF5\uAC04\uACFC
      \uC77C\uD589\uC758 \uADC0\uB97C \uC6B8\uB838\uACE0 \uC874\uC7AC\uB9CC\uC73C\uB85C\uB3C4
      \uC8FC\uBCC0\uC758 \uC0B0\uC18C\uAC00 \uD76C\uBC15\uD574\uC9C0\uBA70 \uC2DC\uC57C\uAC00
      \uC5B4\uC9C0\uB7EC\uC6CC\uC84C\uB2E4. \uC774\uD504\uB9AC\uD2B8\uAC00 \uC190\uC744
      \uBED7\uC790 \uAC70\uB300\uD55C \uD654\uC5FC\uC758 \uC7A5\uBCBD\uC774 \uC77C\uD589\uC744
      \uAC00\uB450\uC5C8\uB2E4."
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uAC80\uC744 \uD718\uB458\uB7EC\uB3C4 \uADF8\uC800 \uD5C8\uACF5\uC744
      \uAC00\uB97C \uBFD0\uC774\uB2E4. \uBD88\uAF43\uC73C\uB85C \uC774\uB8E8\uC5B4\uC9C4
      \uC721\uCCB4\uC5D0\uB294 \uBB3C\uB9AC\uC801\uC778 \uD0C0\uACA9\uC774 \uC804\uD600
      \uD1B5\uD558\uC9C0 \uC54A\uB294\uB2E4. \uCD5C\uC545\uC758 \uC0C1\uC131... \uB188\uC758
      \uBE44\uC6C3\uC74C \uC18C\uB9AC\uAC00 \uACE0\uB9C9\uC744 \uD0DC\uC6B0\uB294
      \uAC83 \uAC19\uB2E4.'"
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: -6702937843246533677, guid: 8f27ca58b55c595408a8e9d94ab8ea73, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC774\uD504\uB9AC\uD2B8"
    text: "\"\uBC1C\uBC84\uB465 \uCCD0 \uBCF4\uC544\uB77C. \uB108\uD76C\uC758 \uC808\uB9DD\uC774
      \uAE4A\uC5B4\uC9C8\uC218\uB85D \uB098\uC758 \uBD88\uAF43\uC740 \uB354\uC6B1
      \uC120\uBA85\uD788 \uD0C0\uC624\uB97C \uD14C\uB2C8.\"\r\n"
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC18C\uD53C\uC544\uB294 \uC774\uB97C \uC545\uBB3C\uBA70 \uC9C0\uD321\uC774\uB97C
      \uACE0\uCCD0 \uC950\uC5C8\uB2E4. \uADF9\uD55C\uC758 \uC5F4\uAE30 \uD0D3\uC5D0
      \uC774\uB9C8\uC5D0\uB294 \uB540\uBC29\uC6B8\uC774 \uB9FA\uD614\uACE0, \uD3C9\uC18C\uC758
      \uB0C9\uC815\uD568\uC740 \uAC04\uB370\uC5C6\uC774 \uC2E0\uACBD\uC9C8\uC801\uC778
      \uBAA9\uC18C\uB9AC\uAC00 \uD130\uC838 \uB098\uC654\uB2E4."
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: 1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC18C\uD53C\uC544"
    text: "\"\uC820\uC7A5...! \uB9D0\uC740 \uB354\uB7FD\uAC8C \uB9CE\uB124! \uB9C8\uB825
      \uB18D\uB3C4\uAC00 \uB108\uBB34 \uB192\uC544\uC11C \uB0B4 \uB9C8\uBC95\uC870\uCC28
      \uD5C8\uACF5\uC5D0\uC11C \uC99D\uBC1C\uD558\uACE0 \uC788\uC5B4...! \uC138\uC2E4\uB9AC\uC544
      \uC5B8\uB2C8, \uB0B4 \uC9C0\uD321\uC774\uC5D0 \uCD95\uBCF5\uC744 \uAC78\uC5B4\uC918\uC694!
      \uBB3C\uC758 \uB9C8\uBC95\uC5D0 \uC2E0\uC131\uB825\uC744 \uB354\uD574\uC57C
      \uD574\uC694!\""
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC138\uC2E4\uB9AC\uC544\uAC00 \uB5A8\uB9AC\uB294 \uB450 \uC190\uC744
      \uAC00\uC2B4\uC5D0 \uBAA8\uC73C\uACE0 \uD544\uC0AC\uC801\uC73C\uB85C \uAE30\uB3C4\uB97C
      \uC62C\uB838\uB2E4. \uC774\uB0B4 \uC18C\uD53C\uC544\uC758 \uC9C0\uD321\uC774
      \uB05D\uC5D0 \uC11C\uB298\uD55C \uCCAD\uBC31\uC0C9\uC758 \uAE30\uC6B4\uC774
      \uAC10\uB3CC\uC558\uB2E4. \uC99D\uBC1C\uD558\uB294 \uC218\uC99D\uAE30 \uC0AC\uC774\uB85C
      \uC18C\uD53C\uC544\uC758 \uCC3D\uBC31\uD55C \uC5BC\uAD74\uC774 \uB4DC\uB7EC\uB0AC\uB2E4."
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
  - characterId: 1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\"\uC774\uAC78\uB85C... \uB05D\uB0B4\uBC84\uB824!\""
    backgroundSprite: {fileID: -656593689415311612, guid: 9e59b68f660e23c4b82c4a51c3e38627, type: 3}
