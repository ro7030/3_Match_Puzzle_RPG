--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d5ebec344a07c0b4fac788942570856a, type: 3}
  m_Name: Before_Chapter2_Stage3
  m_EditorClassIdentifier: Assembly-CSharp::Story.CutsceneData
  cutsceneId: 
  nextSceneName: BattleScene
  isPrologueMode: 1
  clearSaveOnComplete: 0
  dialogueLines:
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uBCF5\uB3C4 \uB05D \uAC70\uB300\uD55C \uC11D\uBB38\uC744 \uC9C0\uB098\uC790,
      \uAD11\uD65C\uD55C \uACF5\uB3D9 \uC911\uC559\uC5D0 \uB300\uAC80\uC744 \uB4E0
      \uAC15\uCCA0 \uAC11\uC637\uC758 \uC218\uD638\uC790\uAC00 \uC11D\uC0C1\uCC98\uB7FC
      \uC11C \uC788\uB2E4."
    backgroundSprite: {fileID: 4184116334029279494, guid: b5f06b4003899504ca7e33bb3806148d, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: -6303427435192040252, guid: 372ae8f6379dc9347810f0fd036848dd, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uCF70\uC544\uC559\u2014\u2014! \uC1F3\uB369\uC774\uAC00 \uBD80\uB52A\uCE58\uB294
      \uAD49\uC74C\uACFC \uD568\uAED8 \uC218\uD638\uC790\uAC00 \uC6C0\uC9C1\uC774\uAE30
      \uC2DC\uC791\uD55C\uB2E4."
    backgroundSprite: {fileID: 4184116334029279494, guid: b5f06b4003899504ca7e33bb3806148d, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: -6303427435192040252, guid: 372ae8f6379dc9347810f0fd036848dd, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC7A5\uB09C\uAE30 \uAC00\uB4DD\uD588\uB358 \uACF5\uAE30\uB294 \uCC28\uAC00\uC6B4
      \uB3CC\uBB38 \uB108\uBA38\uC5D0\uC11C \uBD88\uC5B4\uC624\uB294 \uC704\uC555\uAC10\uC5D0
      \uC21C\uC2DD\uAC04\uC5D0 \uC5BC\uC5B4\uBD99\uC5C8\uB2E4. \uACE0\uB300\uC758
      \uC815\uC801\uC744 \uAE68\uB728\uB9AC\uB294 \uC721\uC911\uD55C \uAD6C\uB3D9\uC74C.
      \uD22C\uAD6C\uC758 \uD2C8\uC0C8\uB85C \uB450 \uAC1C\uC758 \uD478\uB978 \uBD88\uAF43\uC774
      \uBC88\uB729\uC774\uC790, \uC555\uB3C4\uC801\uC778 \uAC70\uAD6C\uAC00 \uC77C\uD589\uC758
      \uC2DC\uC57C\uB97C \uAC00\uB4DD \uCC44\uC6E0\uB2E4.\r\n"
    backgroundSprite: {fileID: 4184116334029279494, guid: b5f06b4003899504ca7e33bb3806148d, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: ' "......!!"'
    backgroundSprite: {fileID: 4184116334029279494, guid: b5f06b4003899504ca7e33bb3806148d, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: -6303427435192040252, guid: 372ae8f6379dc9347810f0fd036848dd, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uACE0\uAC1C\uB97C \uD55C\uAECF \uCE58\uCF1C\uB4E4\uC5B4\uC57C\uB9CC \uBE44\uB85C\uC18C
      \uB188\uC758 \uC5BC\uAD74\uC744 \uB9C8\uC8FC\uD560 \uC218 \uC788\uC5C8\uB2E4.
      \uC721\uC911\uD55C \uB2E4\uB9AC\uAC00 \uBC14\uB2E5\uC5D0 \uC4F8\uB9AC\uBA70
      \uB0B4\uB294 \uC0B4\uBC8C\uD55C \uC1F3\uC18C\uB9AC\uAC00 \uACE0\uB9C9\uC744
      \uCC22\uC744 \uB4EF \uC6B8\uB824 \uD37C\uC84C\uB2E4. '\uC720\uC801\uC758 \uC218\uD638\uC790'\uB294
      \uB9C8\uCE58 \uBC8C\uB808\uB97C \uAD00\uCC30\uD558\uB294 \uAC70\uC778\uCC98\uB7FC,
      \uC555\uB3C4\uC801\uC778 \uACE0\uB3C4\uC5D0\uC11C \uC77C\uD589\uC744 \uAD7D\uC5B4\uC0B4\uD53C\uBA70
      \uD54F\uBE5B \uC704\uC555\uAC10\uC744 \uBFDC\uC5B4\uB0C8\uB2E4."
    backgroundSprite: {fileID: 4184116334029279494, guid: b5f06b4003899504ca7e33bb3806148d, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uC800\uAC83\uC774... \uACE0\uB300\uC758 \uAE30\uC220\uB825\uC778\uAC00.
      \uC228\uC774 \uB9C9\uD78C\uB2E4. \uB2E8\uC21C\uD788 \uD06C\uAE30\uB9CC \uD55C
      \uAC8C \uC544\uB2C8\uC57C. \uB188\uC758 \uB208\uBE5B\uC5D0\uB294 \uAC10\uC815\uC774
      \uC5C6\uB2E4. \uC624\uC9C1 \uCE68\uC785\uC790\uB97C \uBC30\uC81C\uD558\uACA0\uB2E4\uB294
      \uAE30\uACC4\uC801\uC778 \uB0C9\uD639\uD568\uB9CC\uC774 \uC11C\uB824 \uC788\uC5C8\uB2E4.'"
    backgroundSprite: {fileID: 4184116334029279494, guid: b5f06b4003899504ca7e33bb3806148d, type: 3}
  - characterId: 0
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uD3C9\uBC94\uD55C \uACF5\uACA9\uC740 \uD760\uC9D1\uC870\uCC28 \uB098\uC9C0
      \uC54A\uB294\uB2E4. \uB0B4 \uAC80\uB3C4, \uC18C\uD53C\uC544\uC758 \uB9C8\uBC95\uB3C4
      \uB188\uC758 \uB450\uAEBC\uC6B4 \uC7A5\uAC11 \uC55E\uC5D0\uC11C\uB294 \uBB34\uB825\uD588\uB2E4.
      \uD558\uC9C0\uB9CC... \uBC18\uB4DC\uC2DC \uC57D\uC810\uC740 \uC788\uC744 \uD130\uB2E4.'"
    backgroundSprite: {fileID: 4184116334029279494, guid: b5f06b4003899504ca7e33bb3806148d, type: 3}
  - characterId: 1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC18C\uD53C\uC544"
    text: "\"\uB2E4\uC774\uB098! \uB188\uC758 \uD22C\uAD6C \uC0AC\uC774, \uB208\uCC98\uB7FC
      \uBE5B\uB098\uB294 \uCF54\uC5B4\uAC00 \uBCF4\uC774\uC8E0? \uC800\uAE38 \uB6AB\uC73C\uBA74
      \uAC11\uC637\uC774 \uBB34\uB108\uC9C8 \uAC70\uC608\uC694!\""
    backgroundSprite: {fileID: 4184116334029279494, guid: b5f06b4003899504ca7e33bb3806148d, type: 3}
  - characterId: 2
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uB2E4\uC774\uB098"
    text: "\"\uD5E4\uD5E4, \uC815\uBC00 \uC0AC\uACA9\uC740 \uB0B4 \uC804\uBB38\uC774\uC9C0!
      \uB2E4\uB4E4 \uAE38\uB9CC \uD130\uC918!\""
    backgroundSprite: {fileID: 4184116334029279494, guid: b5f06b4003899504ca7e33bb3806148d, type: 3}
