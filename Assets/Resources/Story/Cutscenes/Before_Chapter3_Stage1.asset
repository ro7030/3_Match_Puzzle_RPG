  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d5ebec344a07c0b4fac788942570856a, type: 3}
  m_Name: Before_Chapter3_Stage1
  m_EditorClassIdentifier: Assembly-CSharp::Story.CutsceneData
  cutsceneId: 
  nextSceneName: BattleScene
  isPrologueMode: 1
  clearSaveOnComplete: 0
  dialogueLines:
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC804\uC124 \uC18D \uC6A9\uC758 \uC694\uC0C8, \uADF8 \uC785\uAD6C\uB294
      \uC0C1\uC0C1 \uC774\uC0C1\uC758 \uC9C0\uC625\uC774\uC5C8\uB2E4. \uBC1C\uBC11\uC73C\uB85C
      \uD750\uB974\uB294 \uC6A9\uC554\uC758 \uC5F4\uAE30\uC5D0 \uB300\uAE30\uAC00
      \uD750\uBB3C\uAC70\uB9AC\uB4EF \uC77C\uB801\uC600\uACE0, \uC720\uC801\uC758
      \uD55C\uAE30\uB294 \uC628\uB370\uAC04\uB370\uC5C6\uC774 \uC0AC\uB77C\uC84C\uB2E4.
      \uC77C\uD589\uC774 \uC5F4\uAE30\uC5D0 \uC555\uB3C4\uB2F9\uD574 \uBA48\uCE6B\uAC70\uB9AC\uB294
      \uC21C\uAC04, \uC694\uC0C8\uC758 \uC548\uCABD\uC5D0\uC11C \uAE30\uAD34\uD55C
      \uC0B4\uAE30\uAC00 \uBFDC\uC5B4\uC838 \uB098\uC654\uB2E4."
    backgroundSprite: {fileID: -111404599429950948, guid: 20581b130e9687f41b8d35d64691650a, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: -1941199619730336998, guid: 72abc112f4819dd45a8b92c72f88db47, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\uBD89\uAC8C \uD0C0\uC624\uB974\uB294 \uC6A9\uC554\uC744 \uB6AB\uACE0,
      \uB9C8\uCE58 \uBD88\uAF43 \uADF8 \uC790\uCCB4\uAC00 \uD615\uC0C1\uD654\uB41C
      \uB4EF\uD55C \uC874\uC7AC\uAC00 \uACE0\uC5F4\uC758 \uB300\uAE30 \uC18D\uC73C\uB85C
      \uBAA8\uC2B5\uC744 \uB4DC\uB7EC\uB0C8\uB2E4. \uADF8\uAC83\uC740 \uC628\uBAB8\uC5D0
      \uC6A9\uC554\uC758 \uACB0\uC815\uC744 \uBC15\uC544 \uB123\uC740 \uB4EF\uD55C
      \uBD89\uC740 \uBE44\uB298\uC744 \uB450\uB978 \uB9AC\uC790\uB4DC\uB9E8\uC774\uC5C8\uB2E4.
      \uC624\uD06C\uC758 \uC655\uC5D0 \uB9DE\uBA39\uB294 \uAC70\uAD6C\uB294 \uC6A9\uC758
      \uB9C8\uB825\uC5D0 \uC7A0\uC2DD\uB2F9\uD55C \uB4EF, \uC804\uC2E0\uC5D0\uC11C
      \uD478\uB978 \uBD88\uAF43\uC744 \uB0B4\uBFDC\uC73C\uBA70 \uC77C\uD589\uC744
      \uB0B4\uB824\uB2E4\uBCF4\uC558\uB2E4.\r\n"
    backgroundSprite: {fileID: -111404599429950948, guid: 20581b130e9687f41b8d35d64691650a, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: -1941199619730336998, guid: 72abc112f4819dd45a8b92c72f88db47, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC790\uB4DC\uB9E8\uC740 \uAC70\uB300\uD55C \uCCA0\uD1F4\uB97C \uAC00\uBCCD\uAC8C
      \uD718\uB450\uB974\uBA70 \uC804\uD22C \uD0DC\uC138\uB97C \uAC16\uCDC4\uB2E4.
      \uB188\uC758 \uB208\uB3D9\uC790\uB294 \uC774\uC131\uC744 \uC783\uC740 \uCC44
      \uC624\uC9C1 \uCE68\uC785\uC790\uB97C \uBC30\uC81C\uD558\uACA0\uB2E4\uB294
      \uC0B4\uC758\uB85C\uB9CC \uBC88\uB729\uC600\uB2E4. \uAC70\uAD6C\uAC00 \uAD6C\uC0AC\uD55C\uB2E4\uACE0\uB294
      \uBBFF\uAE30\uC9C0 \uC54A\uC744 \uB9CC\uD07C \uC815\uAD50\uD558\uACE0 \uD750\uD2B8\uB7EC\uC9D0
      \uC5C6\uB294 \uAC00\uB4DC \uC790\uC138\uB294, \uB188\uC774 \uC6A9\uC758 \uC694\uC0C8\uB97C
      \uC9C0\uD0A4\uB294 \uC219\uB828\uB41C \uAC10\uC2DC\uC790\uC784\uC744 \uC99D\uBA85\uD558\uACE0
      \uC788\uC5C8\uB2E4."
    backgroundSprite: {fileID: -111404599429950948, guid: 20581b130e9687f41b8d35d64691650a, type: 3}
  - characterId: 2
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uB2E4\uC774\uB098"
    text: "\"\uC774 \uB140\uC11D... \uBE44\uB298\uC774 \uB108\uBB34 \uB2E8\uB2E8\uD574!
      \uAC8C\uB2E4\uAC00 \uC774 \uC5F4\uAE30 \uB54C\uBB38\uC5D0 \uBAB8\uC5D0 \uD798\uC774
      \uC548 \uB4E4\uC5B4\uAC00... \uD654\uC0B4\uC774 \uD295\uACA8 \uB098\uAC08 \uAC83
      \uAC19\uC544.\""
    backgroundSprite: {fileID: -111404599429950948, guid: 20581b130e9687f41b8d35d64691650a, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uB2E4\uC774\uB098\uB294 \uAC70\uCE5C \uC228\uC744 \uB0B4\uC26C\uBA70,
      \uD3C9\uC18C\uC640\uB294 \uB2E4\uB974\uAC8C \uD65C \uC2DC\uC704\uB97C \uB2F9\uAE30\uB294
      \uAC83 \uC870\uCC28 \uD798\uB4E4\uC5B4 \uD558\uACE0 \uC788\uC5C8\uB2E4."
    backgroundSprite: {fileID: -111404599429950948, guid: 20581b130e9687f41b8d35d64691650a, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC138\uC2E4\uB9AC\uC544\uB294 \uB5A8\uB9AC\uB294 \uC190\uC73C\uB85C \uAC00\uC2B4\uD30D\uC758
      \uC2ED\uC790\uAC00\uB97C \uAF49 \uC6C0\uCF1C\uC950\uC5C8\uB2E4. \uADF8\uB140\uAC00
      \uAE30\uB3C4\uB97C \uC74A\uC870\uB9AC\uC790, \uC2ED\uC790\uAC00\uC5D0\uC11C
      \uD478\uB978\uBE5B\uC758 \uC131\uC2A4\uB7EC\uC6B4 \uD30C\uB3D9\uC774 \uD37C\uC838\uB098\uAC00\uBA70
      \uC77C\uD589\uC744 \uAC10\uC30C\uB2E4. \uAE30\uC801\uC758 \uBE5B\uC774 \uB2FF\uB294
      \uACF3\uB9C8\uB2E4 \uC694\uC0C8\uC758 \uC9C0\uC625 \uAC19\uC740 \uC5F4\uAE30\uAC00
      \uC7A6\uC544\uB4E4\uACE0, \uBA54\uB9D0\uB790\uB358 \uB3D9\uB8CC\uB4E4\uC758
      \uD53C\uBD80\uC5D0 \uC0DD\uAE30\uAC00 \uB3CC\uAE30 \uC2DC\uC791\uD588\uB2E4."
    backgroundSprite: {fileID: -111404599429950948, guid: 20581b130e9687f41b8d35d64691650a, type: 3}
  - characterId: 3
    characterSpriteOverride: {fileID: 0}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: "\uC138\uC2E4\uB9AC\uC544"
    text: "\"\uBAA8\uB450 \uC81C \uACC1\uC73C\uB85C \uC624\uC138\uC694! \uC2E0\uC758
      \uAC00\uD638\uAC00 \uC774 \uC5F4\uAE30\uB97C \uC7A0\uC2DC\uB098\uB9C8 \uC2DD\uD600\uC904
      \uAC70\uC608\uC694. \uC815\uD654\uC758 \uBE5B\uC774\uC5EC, \uC6B0\uB9AC\uC758
      \uAC80\uC744 \uB2E8\uB2E8\uCF00 \uD558\uC18C\uC11C!\"\r\n"
    backgroundSprite: {fileID: -111404599429950948, guid: 20581b130e9687f41b8d35d64691650a, type: 3}
  - characterId: -1
    characterSpriteOverride: {fileID: -1941199619730336998, guid: 72abc112f4819dd45a8b92c72f88db47, type: 3}
    characterId2: -1
    characterSpriteOverride2: {fileID: 0}
    characterId3: -1
    characterSpriteOverride3: {fileID: 0}
    speakerName: 
    text: "\uC138\uC2E4\uB9AC\uC544\uC758 \uC815\uD654 \uB9C8\uBC95\uC774 \uC131\uACF5\uD558\uC790,
      \uC5D8\uB9AC\uC57C\uB294 \uAC80\uC744 \uCE58\uCF1C\uB4E4\uBA70 \uB9AC\uC790\uB4DC\uB9E8\uC744
      \uD5A5\uD574 \uB3CC\uC9C4\uD588\uB2E4."
    backgroundSprite: {fileID: -111404599429950948, guid: 20581b130e9687f41b8d35d64691650a, type: 3}
