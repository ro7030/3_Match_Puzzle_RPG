--- !u!114 &1607523198
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1607523197}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e34ee42885b1a3740b65e63a71f8ad8a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Story.StoryDialogueController
  speakerNameText: {fileID: 732038045}
  dialogueText: {fileID: 746354845}
  dialogueBox: {fileID: 2028044365}
  clickAreaButton: {fileID: 712738831}
  backgroundImage: {fileID: 237795926}
  characterImage: {fileID: 124406763}
  characterImage2: {fileID: 124412001}
  characterImage3: {fileID: 124412011}
  characterDatabase: {fileID: 0}
  textTyper: {fileID: 0}
  skipButton: {fileID: 684294689}
  scriptButton: {fileID: 1939491201}
  settingsButton: {fileID: 612081548}
  uiToggleButton: {fileID: 665068716}
  uiRestorePanel: {fileID: 970704823}
  scriptPanel: {fileID: 844676659}
  scriptScrollRect: {fileID: 1280888230}
  scriptScrollText: {fileID: 1935958440}
  scriptCloseButton: {fileID: 1262945843}
  nextSceneName: TutorialScene
  isPrologueMode: 1
  dialogueLines:
  - speakerName: 
    text: "\"\uBA3C \uC61B\uB0A0, \uC138\uC0C1\uC740 \uAC70\uB300\uD55C \uB0A0\uAC1C
      \uADF8\uB9BC\uC790\uC5D0 \uAC00\uB824\uC838 \uC788\uC5C8\uB2E8\uB2E4. \uD3EC\uC545\uD55C
      \uC6A9 '\uBCFC\uCF00\uC778'\uC774 \uB0B4\uBC49\uB294 \uC228\uACB0\uC5D0 \uB300\uC9C0\uB294
      \uBE44\uBA85\uC744 \uC9C8\uB800\uACE0, \uB9C8\uBB3C\uB4E4\uC774 \uB4E4\uB053\uC5B4
      \uC0AC\uB78C\uB4E4\uC740 \uC228\uC8FD\uC5EC \uC6B8\uC5B4\uC57C\uB9CC \uD588\uC9C0.\""
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: 756594752419707314, guid: a9746d5107f1ac14d920268c4b54a5b9, type: 3}
  - speakerName: 
    text: "\"\uD558\uC9C0\uB9CC \uC808\uB9DD \uC18D\uC5D0\uC11C\uB3C4 \uBE5B\uC740
      \uD53C\uC5B4\uB098\uB294 \uBC95. \uB2F9\uB300 \uCD5C\uACE0\uC758 \uAE30\uC0AC\uC640
      \uB9C8\uBC95\uC0AC, \uBAA8\uD5D8\uAC00\uC640 \uC218\uB140... \uB124 \uBA85\uC758
      \uC601\uC6C5\uC774 \uC624\uC9C1 \uD76C\uB9DD \uD558\uB098\uB9CC\uC744 \uD488\uACE0
      \uC694\uC0C8\uB85C \uD5A5\uD588\uB2E8\uB2E4. \uB9C8\uBB3C\uB4E4\uC774 \uC55E\uAE38\uC744
      \uAC00\uB85C\uB9C9\uB294 \uC232\uC744 \uD5E4\uCE58\uACE0,\""
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: -1201275793365445474, guid: 3e0c32e1d31dae745b1fc6fd8053bcd1, type: 3}
  - speakerName: 
    text: "\"\uC11C\uB298\uD55C \uC8FD\uC74C\uC758 \uD568\uC815\uC774 \uB3C4\uC0AC\uB9AC\uB294
      \uACE0\uB300 \uC720\uC801\uC744 \uB118\uC5B4 \uB9C8\uCE68\uB0B4 \uACB0\uC804\uC758
      \uB545\uC5D0 \uB2FF\uC558\uC9C0.\" "
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: 4881464195750903693, guid: 5f5bf4f03866c244ba8530bea57ea769, type: 3}
  - speakerName: 
    text: "\"\uCE58\uC5F4\uD55C \uC0AC\uD22C \uB05D\uC5D0 \uBCFC\uCF00\uC778\uC740
      \uAE4A\uC740 \uC7A0\uC5D0 \uBE60\uC84C\uACE0,\""
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: 1452844287233580040, guid: 45d13c8936845414bbce9eb13066d3a6, type: 3}
  - speakerName: 
    text: "\"\uC601\uC6C5\uB4E4\uC740 \uC804\uC124\uC774 \uB418\uC5B4 \uB3CC\uC544\uC654\uB2E8\uB2E4.
      \uB300\uC9C0\uC5D0\uB294 \uB2E4\uC2DC \uD478\uB978 \uC2F9\uC774 \uB3CB\uC544\uB0AC\uACE0
      \uB9C8\uBB3C\uB4E4\uC740 \uADF8\uB9BC\uC790 \uC18D\uC73C\uB85C \uC790\uCDE8\uB97C
      \uAC10\uCDC4\uC9C0.\""
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: -8756523405737439449, guid: 5b68b49b6b31d9e4aafe0407d6936793, type: 3}
  - speakerName: 
    text: "\"\uC6A9\uC0AC\uB294 \uB9C8\uC9C0\uB9C9 \uC228\uC744 \uAC70\uB450\uAE30
      \uC804, \uC57D\uC18D \uD558\uB098\uB97C \uB0A8\uACBC\uC5B4. '\uBCFC\uCF00\uC778\uC774
      \uB2E4\uC2DC \uB208\uC744 \uB728\uB294 \uB0A0, \uC774 \uAC80\uC740 \uB2E4\uC2DC\uAE08
      \uBE5B\uC744 \uB0B4\uC5B4 \uAE38\uC744 \uBC1D\uD788\uB9AC\uB77C.' \uC0AC\uB78C\uB4E4\uC740
      \uADF8\uB0A0\uC744 \uAE30\uB9AC\uBA70 '\uC2E0\uC131\uB825'\uC758 \uC2DC\uB300\uB97C
      \uC5F4\uC5C8\uACE0, \uC601\uC6C5\uB4E4\uC758 \uBB34\uAE30\uB294 \uADF8 \uC758\uC9C0\uB97C
      \uC774\uC744 \uC790\uB4E4\uC5D0\uAC8C \uB300\uB300\uB85C \uC804\uD574\uC84C\uB2E8\uB2E4.\" "
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: 6608672641556784057, guid: 44fded1d4096fb740921e761fa3b1bca, type: 3}
  - speakerName: "\uC5B4\uB9B0 \uC5D8\uB9AC\uC57C"
    text: "\"\uC5C4\uB9C8! \uB098 \uACB0\uC2EC\uD588\uC5B4. \uB098\uB3C4 \uC800 \uC6A9\uC0AC\uB2D8\uCC98\uB7FC
      \uB420 \uAC70\uC57C! \uC6A9\uC0AC\uAC00 \uB418\uC5B4\uC11C \uC2AC\uD37C\uD558\uB294
      \uC0AC\uB78C\uB4E4\uC744 \uC804\uBD80 \uAD6C\uD574\uC904 \uAC70\uC57C!\" "
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: -3597277113461577536, guid: 45651b5373a89bf418c2b3448f28ba7a, type: 3}
  - speakerName: 
    text: "\uC5B4\uBA38\uB2C8\uB294 \uD587\uC0B4 \uAC19\uC740 \uBBF8\uC18C\uB97C
      \uC9C0\uC73C\uBA70 \uC5D8\uB9AC\uC57C\uC758 \uD5DD\uD074\uC5B4\uC9C4 \uBA38\uB9AC\uCE7C\uC744
      \uB2E4\uC815\uD558\uAC8C \uC4F8\uC5B4 \uB118\uACBC\uB2E4."
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: -3597277113461577536, guid: 45651b5373a89bf418c2b3448f28ba7a, type: 3}
  - speakerName: "\uC5D8\uB9AC\uC57C\uC758 \uC5B4\uBA38\uB2C8"
    text: "\"\uADF8\uB798, \uC5D8\uB9AC\uC57C. \uAF2D \uC6A9\uC0AC\uAC00 \uB418\uC5B4
      \uC0AC\uB78C\uB4E4\uC744 \uC9C0\uD0A4\uB294 \uB4E0\uB4E0\uD55C \uAC80\uC774
      \uB418\uC5B4\uC8FC\uB834. \uC5C4\uB9C8\uC640 \uC57D\uC18D\uD560 \uC218 \uC788\uC9C0?\""
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: -3597277113461577536, guid: 45651b5373a89bf418c2b3448f28ba7a, type: 3}
  - speakerName: "\uC5B4\uB9B0 \uC5D8\uB9AC\uC57C "
    text: "\"\uC751! \uC57D\uC18D\uD574!\""
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: -3597277113461577536, guid: 45651b5373a89bf418c2b3448f28ba7a, type: 3}
  - speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uBA38\uB9AC\uAC00 \uAE68\uC9C8 \uB4EF\uC774 \uC6B8\uB9B0\uB2E4. \uBC29\uAE08\uAE4C\uC9C0
      \uB0B4 \uBA38\uB9AC\uB97C \uC4F0\uB2E4\uB4EC\uB358 \uC5B4\uBA38\uB2C8\uC758
      \uC628\uAE30\uB294 \uAC04\uB370\uC5C6\uACE0, \uC9C0\uB3C5\uD55C \uC720\uD669
      \uB0C4\uC0C8\uC640 \uBB34\uC5B8\uAC00 \uD0C0\uB4E4\uC5B4 \uAC00\uB294 \uB9E4\uCE90\uD55C
      \uC5F0\uAE30\uAC00 \uD3D0\uBD80\uB97C \uCC14\uB800\uB2E4.' "
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: 6558155441594556298, guid: 293e91c1221d86b48999f4d2edca1edb, type: 3}
  - speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uC73D, \uC73C\uC73C... \uC5EC\uAE34...?\""
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: 6558155441594556298, guid: 293e91c1221d86b48999f4d2edca1edb, type: 3}
  - speakerName: 
    text: "\uBB34\uAC70\uC6B4 \uB208\uAEBC\uD480\uC744 \uB4E4\uC5B4 \uC62C\uB9B0
      \uC5D8\uB9AC\uC57C\uB97C \uB9DE\uC774\uD55C \uAC83\uC740 \uB354 \uC774\uC0C1
      \uD3C9\uD654\uB85C\uC6B4 \uC544\uB974\uCE74\uB514\uC544\uC758 \uD587\uC0B4\uC774
      \uC544\uB2C8\uC5C8\uB2E4. \uAD11\uC7A5\uC740 \uC7BF\uB354\uBBF8\uB85C \uBCC0\uD574
      \uC788\uC5C8\uACE0, \uBE44\uBA85 \uC11E\uC778 \uC18C\uC6A9\uB3CC\uC774 \uC18D\uC5D0\uC11C
      \uC0AC\uB78C\uB4E4\uC740 \uC815\uCCB4 \uBAA8\uB97C \uADF8\uB9BC\uC790\uB4E4\uC5D0\uAC8C
      \uCAD3\uAE30\uACE0 \uC788\uC5C8\uB2E4. "
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: 6558155441594556298, guid: 293e91c1221d86b48999f4d2edca1edb, type: 3}
  - speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uBBFF\uC744 \uC218 \uC5C6\uB2E4. \uB9C8\uBB3C\uB4E4\uC774 \uC655\uAD6D
      \uD55C\uBCF5\uD310\uC5D0 \uB098\uD0C0\uB098\uB2E4\uB2C8. \uC774\uAC74 \uAFC8\uC774\uB2E4.
      \uC545\uBABD\uC774\uC5B4\uC57C\uB9CC \uD55C\uB2E4. \uD558\uC9C0\uB9CC \uC190\uBC14\uB2E5\uC744
      \uD0C0\uACE0 \uC804\uD574\uC9C0\uB294 \uB3CC\uBC14\uB2E5\uC758 \uB728\uAC70\uC6B4
      \uC5F4\uAE30\uB294 \uC774\uAC83\uC774 \uC9C0\uB3C5\uD55C \uD604\uC2E4\uC784\uC744
      \uC99D\uBA85\uD558\uACE0 \uC788\uC5C8\uB2E4.' "
    characterSprite: {fileID: -9052037539496166500, guid: 2e6d2a7a424fd004ca9957f040f6902e, type: 3}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: 6558155441594556298, guid: 293e91c1221d86b48999f4d2edca1edb, type: 3}
  - speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uB9C8\uBB3C\uB4E4...? \uC5B4\uC9F8\uC11C \uB9C8\uC744\uAE4C\uC9C0...
      \uB300\uCCB4 \uBB34\uC2A8 \uC77C\uC774...\""
    characterSprite: {fileID: -9052037539496166500, guid: 2e6d2a7a424fd004ca9957f040f6902e, type: 3}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: 6558155441594556298, guid: 293e91c1221d86b48999f4d2edca1edb, type: 3}
  - speakerName: 
    text: "\uD63C\uB780\uC5D0 \uBE60\uC9C4 \uADF8\uC758 \uC2DC\uC57C \uB05D\uC5D0\uC11C,
      \uC774\uC9C8\uC801\uC778 \uBE5B \uD558\uB098\uAC00 \uC77C\uB801\uC600\uB2E4."
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: -6414429958397297553, guid: 446e3a3c25f773b418d1718b328bb05c, type: 3}
  - speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uAC80\uC774... \uBE5B\uB098\uACE0 \uC788\uC5B4?\""
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: -6414429958397297553, guid: 446e3a3c25f773b418d1718b328bb05c, type: 3}
  - speakerName: 
    text: "\uAE30\uC0AC\uB2E8\uC7A5\uC774 \uB418\uB358 \uB0A0 \uAD6D\uC655\uC5D0\uAC8C
      \uD558\uC0AC\uBC1B\uC558\uB358 \uB0A1\uC740 \uAC80. \uAC00\uBCF4\uB85C\uB9CC
      \uC5EC\uACA8\uC84C\uB358 \uADF8 \uCCA0\uAC80\uC774 \uB9C8\uCE58 \uC2EC\uC7A5\uC774
      \uB6F0\uB4EF \uACE0\uB3D9\uCE58\uBA70 \uC2DC\uB9B0 \uD478\uB978 \uAD11\uCC44\uB97C
      \uD1A0\uD574\uB0B4\uACE0 \uC788\uC5C8\uB2E4. "
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: -6414429958397297553, guid: 446e3a3c25f773b418d1718b328bb05c, type: 3}
  - speakerName: "\uC5D8\uB9AC\uC57C"
    text: "'\uC5B4\uBA38\uB2C8\uC640 \uC77D\uB358 \uB3D9\uD654\uCC45 \uC18D\uC758
      \uD55C \uAD6C\uC808\uC774 \uBCBC\uB77D\uCC98\uB7FC \uBA38\uB9BF\uC18D\uC744
      \uC2A4\uCCE4\uB2E4. \uC804\uC124\uC740 \uD5C8\uAD6C\uAC00 \uC544\uB2C8\uC5C8\uB2E4.
      \uADF8\uAC83\uC740 \uAE30\uB85D\uB418\uC9C0 \uBABB\uD55C \uC608\uC5B8\uC774\uC5C8\uACE0,
      \uC9C0\uAE08 \uB0B4 \uC190\uC5D0\uC11C \uC228\uC744 \uC26C\uACE0 \uC788\uB2E4.' "
    characterSprite: {fileID: 0}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: -6414429958397297553, guid: 446e3a3c25f773b418d1718b328bb05c, type: 3}
  - speakerName: "\uC5D8\uB9AC\uC57C"
    text: "\"\uBAA8\uB450 \uC81C \uB4A4\uB85C \uB300\uD53C\uD558\uC2ED\uC2DC\uC624!
      \uC5EC\uAE30\uC11C\uBD80\uD130\uB294... \uC544\uB974\uCE74\uB514\uC544 \uAE30\uC0AC\uB2E8\uC774
      \uAE38\uC744 \uC5F4\uACA0\uC2B5\uB2C8\uB2E4!\" "
    characterSprite: {fileID: -9052037539496166500, guid: 2e6d2a7a424fd004ca9957f040f6902e, type: 3}
    characterSprite2: {fileID: 0}
    characterSprite3: {fileID: 0}
    backgroundSprite: {fileID: 6558155441594556298, guid: 293e91c1221d86b48999f4d2edca1edb, type: 3}
